@using ERP_SOLUTIONS.Enum
@using ERP_SOLUTIONS.Models.DTOS
@model IEnumerable<TeacherDto>

@{
    ViewData["Title"] = "Teachers";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container mt-5">
    <!-- Header + Add Teacher -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="text-primary">
            <i class="bi bi-people-fill me-2"></i> Teachers Management
        </h2>
        <a class="btn btn-success" href="@Url.Action("Create")">
            <i class="bi bi-plus-circle me-1"></i> Add Teacher
        </a>
    </div>

    <!-- TempData Messages -->
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert" id="successMessage">
            <i class="bi bi-check-circle-fill me-2"></i> @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert" id="errorMessage">
            <i class="bi bi-exclamation-triangle-fill me-2"></i> @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <!-- Search Form -->
    <form method="get" class="mb-3">
        <div class="input-group">
            <span class="input-group-text bg-primary text-white">
                <i class="bi bi-search"></i>
            </span>
            <input type="text" name="search" class="form-control" placeholder="Search by Name, Phone, Email, or Qualification" value="@ViewBag.Search" />
            <button class="btn btn-primary" type="submit">Search</button>
        </div>
    </form>

    <div class="modal fade" id="statusModal" tabindex="-1" data-bs-backdrop="static"
         data-bs-keyboard="false">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content shadow-lg border-0">

                <form id="statusForm">

                    <!-- Header -->
                    <div class="modal-header bg-light border-0">
                        <h5 class="modal-title d-flex align-items-center gap-2">
                            <i class="bi bi-person-check-fill text-success fs-4"></i>
                            Update Teacher Status
                        </h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                    </div>

                    <!-- Body -->
                    <div class="modal-body px-4 py-3">
                        <input type="hidden" id="teacherId" name="Id" />

                        <!-- Status -->
                        <div class="mb-4">
                            <label class="form-label fw-semibold">
                                <i class="bi bi-flag me-1 text-primary"></i> Status
                            </label>
                            <select class="form-select" name="Status" id="status">
                                <option value="0">🟢 Active</option>
                                <option value="1">🟡 Resigned</option>
                                <option value="2">🔵 Left</option>
                                <option value="3">🔴 Blocked</option>
                            </select>
                        </div>

                        <!-- Remark -->
                        <div class="mb-2">
                            <label class="form-label fw-semibold">
                                <i class="bi bi-chat-left-text me-1 text-secondary"></i> Remark
                            </label>
                            <textarea class="form-control" name="StatusRemark" rows="3"
                                      placeholder="Add a note (optional)..."></textarea>
                        </div>
                    </div>

                    <!-- Footer -->
                    <div class="modal-footer border-0 px-4 pb-4">
                        <button type="button" class="btn btn-light px-4" data-bs-dismiss="modal">
                            <i class="bi bi-x-circle me-1"></i> Cancel
                        </button>

                        <button type="button" class="btn btn-success px-4" onclick="saveStatus()">
                            <i class="bi bi-check-circle-fill me-1"></i> Save Changes
                        </button>
                    </div>

                </form>

            </div>
        </div>
    </div>

    <!-- Teachers Table -->
    <div class="table-responsive">
        <table class="table table-striped table-hover align-middle">
            <thead class="table-dark text-center">
                <tr>
                    <th>#</th>
                    <th align="left"></th>
                    <th align="left">Teacher Name</th>
                    <th align="left">Gender</th>
                    <th align="right">Phone</th>
                    <th align="left">Email ID</th>
                    <th align="left">Qualification</th>
                    <th align="left">Designation</th>
                    <th align ="left">Specialization</th>
                    <th align="left">Actions</th>
                    <th>Status</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Any())
                {
                    int serial = ((ViewBag.CurrentPage - 1) * 10) + 1;
                    <!-- for server-side paging -->
                    foreach (var teacher in Model)
                    {
                        <tr class="text-center">
                            <td><b>@serial</b></td>
                            <td>
                                @if (teacher.Status == TeacherStatus.Active)
                                {
                                    <span class="text-success">
                                        <i class="bi bi-check-circle-fill"></i> Active
                                    </span>
                                }
                                else if (teacher.Status == TeacherStatus.Blocked)
                                {
                                    <span class="text-danger">
                                        <i class="bi bi-slash-circle-fill"></i> Blocked
                                    </span>
                                }
                                else if (teacher.Status == TeacherStatus.Resigned)
                                {
                                    <span class="text-warning">
                                        <i class="bi bi-box-arrow-right"></i> Resigned
                                    </span>
                                }
                                else if (teacher.Status == TeacherStatus.Left)
                                {
                                    <span class="text-secondary">
                                        <i class="bi bi-person-dash"></i> Left
                                    </span>
                                }
                            </td>
                            <td class="text-start">
                                <i class="bi bi-person-fill text-secondary me-2"></i>
                                @teacher.TeacherName
                            </td>
                            <td> <i class="bi bi-person-fill text-secondary me-2"></i>@teacher.Gender</td>
                            <td>
                                <i class="bi bi-telephone-fill text-primary me-1"></i>
                                <a href="tel:@teacher.Phone">@teacher.Phone</a>
                            </td>
                            <td>
                                <i class="bi bi-envelope-fill text-danger me-1"></i>
                                <a href="mailto:@teacher.EmailID">@teacher.EmailID</a>
                            </td>
                            <td>
                                <i class="bi bi-mortarboard-fill text-success me-1"></i>
                                @teacher.Qualification
                            </td>
                            <td>@teacher.Designation</td>
                            <td>@teacher.Specialization</td>
                            <td>
                                <a class="btn btn-sm btn-info me-1" href="@Url.Action("Edit", new { id = teacher.TeacherID })">
                                    <i class="bi bi-pencil"></i></a>
                                <a class="btn btn-sm btn-danger" href="@Url.Action("Delete", new { id = teacher.TeacherID })">
                                    <i class="bi bi-trash"></i></a>
                            </td>
                            <td>
                                <button class="btn btn-sm btn-outline-primary"
                                        onclick="openStatusModal(@teacher.TeacherID, '@teacher.Status')">
                                    <i class="bi bi-person-gear me-1"></i> Manage
                                </button>
                            </td>
                        </tr>
                        serial++;
                    }
                }
                else
                {
                    <tr>
                        <td colspan="9" class="text-center fw-bold">No teachers found.</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <!-- Pagination -->
    @if (ViewBag.TotalPages > 1)
    {
        <nav aria-label="Page navigation">
            <ul class="pagination justify-content-center">
                <li class="page-item @(ViewBag.CurrentPage == 1 ? "disabled" : "")">
                    <a class="page-link" href="?search=@ViewBag.Search&page=@(ViewBag.CurrentPage - 1)">Previous</a>
                </li>

                @for (int i = 1; i <= ViewBag.TotalPages; i++)
                {
                    <li class="page-item @(i == ViewBag.CurrentPage ? "active" : "")">
                        <a class="page-link" href="?search=@ViewBag.Search&page=@i">@i</a>
                    </li>
                }

                <li class="page-item @(ViewBag.CurrentPage == ViewBag.TotalPages ? "disabled" : "")">
                    <a class="page-link" href="?search=@ViewBag.Search&page=@(ViewBag.CurrentPage + 1)">Next</a>
                </li>
            </ul>
        </nav>
    }
</div>

@section Scripts {

    <script>

        // Auto-hide TempData messages
        setTimeout(function () {
            const success = document.getElementById('successMessage');
            const error = document.getElementById('errorMessage');
            if (success) { success.classList.remove('show'); success.classList.add('fade'); }
            if (error) { error.classList.remove('show'); error.classList.add('fade'); }
        }, 5000);

        function openStatusModal(id, status) {
            document.getElementById("teacherId").value = id;
            document.getElementById("status").value = status;

            var modal = new bootstrap.Modal(document.getElementById('statusModal'));
            modal.show();
        }

        function saveStatus() {
            var formData = {
                Id: document.getElementById("teacherId").value,
                Status: document.getElementById("status").value,
                StatusRemark: document.querySelector("textarea[name='StatusRemark']").value
            };

            fetch('/Teacher/UpdateStatus', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json'
                },
                body: JSON.stringify(formData)
            })
            .then(res => res.json())
            .then(data => {
                if (data.success) {
                    location.reload(); // refresh table
                }
            });
        }



    </script>
}