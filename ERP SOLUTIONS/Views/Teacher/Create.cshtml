@using ERP_SOLUTIONS.Models.Entities
@model Teacher
@{
    ViewData["Title"] = Model.TeacherID == 0 ? "Add Teacher" : "Edit Teacher";
    Layout = "~/Views/Shared/_Layout.cshtml";
    bool isEdit = Model != null && Model.TeacherID > 0;
}

@* <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css" rel="stylesheet"> *@

<style>
    /* Make checkbox border more visible */
    .form-check-input {
        width: 20px; /* bigger size */
        height: 20px;
        border: 2px solid #0d6efd; /* blue border */
        background-color: #fff;
    }

        /* Checked state color */
        .form-check-input:checked {
            background-color: #0d6efd; /* blue background */
            border-color: #0d6efd;
        }
</style>

<div class="container mt-4">
    <div class="card shadow-sm">
        <div class="card-header bg-primary text-white">
            <h4 class="mb-0"><i class="bi bi-person-plus"></i> @ViewData["Title"]</h4>
        </div>

        @* <form asp-action="Create" method="post"> *@
        <form asp-action="@(isEdit ? "Edit" : "Create")" method="post">
            <div class="card-body">
                @if (isEdit)
                {
                    <input type="hidden" asp-for="TeacherID" />
                }
                <!-- 🧾 Personal Info -->
                <h5 class="mb-3 text-secondary"><i class="bi bi-person"></i> Personal Info</h5>
                <div class="row mb-3">
                    <div class="col-md-6">
                        <label asp-for="FullName" class="form-label"><i class="bi bi-card-text"></i> Full Name</label>
                        <input asp-for="FullName" class="form-control" />
                        <span asp-validation-for="FullName" class="text-danger"></span>
                    </div>
                    <div class="col-md-3">
                        <label asp-for="GenderID" class="form-label"><i class="bi bi-gender-ambiguous"></i> Gender</label>
                        <select asp-for="GenderID" class="form-select">
                            <option value="">-- Select --</option>
                            <option value="1">Male</option>
                            <option value="2">Female</option>
                            <option value="3">Other</option>
                        </select>
                        <span asp-validation-for="GenderID" class="text-danger"></span>
                    </div>
                    <div class="col-md-3">
                        <label asp-for="DateOfBirth" class="form-label"><i class="bi bi-calendar-date"></i> DOB</label>
                        <input asp-for="DateOfBirth" type="date" class="form-control" />
                        <span asp-validation-for="DateOfBirth" class="text-danger"></span>
                    </div>
                </div>
                <div class="row mb-3">
                    <div class="col-md-3">
                        <label asp-for="Aadhaar" class="form-label"><i class="bi bi-credit-card-2-back"></i> Aadhaar</label>
                        <input asp-for="Aadhaar" class="form-control" />
                        <span asp-validation-for="Aadhaar" class="text-danger"></span>
                    </div>
                    <div class="col-md-3">
                        <label asp-for="BloodGroup" class="form-label"><i class="bi bi-droplet-half"></i> Blood Group</label>
                        <input asp-for="BloodGroup" class="form-control" placeholder="A+, B-, O+, etc." />
                        <span asp-validation-for="BloodGroup" class="text-danger"></span>
                    </div>

                </div>

                <!-- 👨‍👩‍👧 Family Info -->
                <h5 class="mb-3 text-secondary"><i class="bi bi-people"></i> Family Info</h5>
                <div class="row mb-3">
                    <div class="col-md-6">
                        <label asp-for="FatherName" class="form-label"><i class="bi bi-person"></i> Father Name</label>
                        <input asp-for="FatherName" class="form-control" />
                        <span asp-validation-for="FatherName" class="text-danger"></span>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="MotherName" class="form-label"><i class="bi bi-person"></i> Mother Name</label>
                        <input asp-for="MotherName" class="form-control" />
                        <span asp-validation-for="MotherName" class="text-danger"></span>
                    </div>
                </div>
                <div class="row mb-3">
                    <div class="col-md-3 d-flex align-items-center">
                        <div class="form-check">
                            <input asp-for="IsMarried" class="form-check-input" type="checkbox" id="IsMarried">
                            <label class="form-check-label ms-2" for="IsMarried">
                                <i class="bi bi-heart"></i> Married
                            </label>
                        </div>
                    </div>
                    
                    <div class="col-md-4 spouse-fields" style="display:none;">
                        <label asp-for="SpouseName" class="form-label"><i class="bi bi-person"></i> Spouse Name</label>
                        <input asp-for="SpouseName" class="form-control" />
                    </div>
                    <div class="col-md-4 spouse-fields" style="display:none;">
                        <label asp-for="SpouseContact" class="form-label"><i class="bi bi-telephone"></i> Spouse Contact</label>
                        <input asp-for="SpouseContact" class="form-control" />
                    </div>
                </div>

                <!-- 📞 Contact Info -->
                <h5 class="mb-3 text-secondary"><i class="bi bi-telephone-fill"></i> Contact Info</h5>
                <div class="row mb-3">
                    <div class="col-md-4">
                        <label asp-for="Phone" class="form-label"><i class="bi bi-telephone"></i> Phone</label>
                        <input asp-for="Phone" class="form-control" />
                        <span asp-validation-for="Phone" class="text-danger"></span>
                    </div>
                    <div class="col-md-4">
                        <label asp-for="EmailID" class="form-label"><i class="bi bi-envelope"></i> Email</label>
                        <input asp-for="EmailID" class="form-control" />
                        <span asp-validation-for="EmailID" class="text-danger"></span>
                    </div>
                    <div class="col-md-4">
                        <label asp-for="EmergencyContact" class="form-label"><i class="bi bi-exclamation-triangle"></i> Emergency Contact</label>
                        <input asp-for="EmergencyContact" class="form-control" />
                        <span asp-validation-for="EmergencyContact" class="text-danger"></span>
                    </div>
                </div>
                <div class="row mb-3">
                    <div class="col-md-6">
                        <label asp-for="PresentAddress" class="form-label"><i class="bi bi-house"></i> Present Address</label>
                        <textarea asp-for="PresentAddress" class="form-control"></textarea>
                        <span asp-validation-for="PresentAddress" class="text-danger"></span>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="PermanentAddress" class="form-label"><i class="bi bi-house-door"></i> Permanent Address</label>
                        <textarea asp-for="PermanentAddress" class="form-control"></textarea>
                        <span asp-validation-for="PermanentAddress" class="text-danger"></span>
                    </div>
                </div>

                <!-- 🎓 Professional Info -->
                <h5 class="mb-3 text-secondary"><i class="bi bi-mortarboard"></i> Professional Info</h5>
                <div class="row mb-3">
                    <div class="col-md-3">
                        <label asp-for="Designation" class="form-label"><i class="bi bi-person-badge"></i> Designation</label>
                        <input asp-for="Designation" class="form-control" />
                        <span asp-validation-for="Designation" class="text-danger"></span>
                    </div>

                    <div class="col-md-3">
                        <label asp-for="Qualification" class="form-label"><i class="bi bi-mortarboard"></i> Qualification</label>
                        <input asp-for="Qualification" class="form-control" />
                        <span asp-validation-for="Qualification" class="text-danger"></span>
                    </div>

                    <div class="col-md-3">
                        <label asp-for="Specialization" class="form-label"><i class="bi bi-journal-text"></i> Specialization</label>
                        <input asp-for="Specialization" class="form-control" />
                        <span asp-validation-for="Specialization" class="text-danger"></span>
                    </div>

                    <div class="col-md-3">
                        <label asp-for="Experience" class="form-label"><i class="bi bi-clock-history"></i> Experience (years)</label>
                        <input asp-for="Experience" type="number" step="0.1" class="form-control" />
                        <span asp-validation-for="Experience" class="text-danger"></span>
                    </div>

                    <div class="col-md-3">
                        <label asp-for="JoiningDate" class="form-label"><i class="bi bi-calendar-check"></i> Joining Date</label>
                        <input asp-for="JoiningDate" type="date" class="form-control" />
                        <span asp-validation-for="JoiningDate" class="text-danger"></span>
                    </div>

                    <div class="col-md-3">
                        <label asp-for="LastWorkingDate" class="form-label"><i class="bi bi-calendar-x"></i> Last Working Date</label>
                        <input asp-for="LastWorkingDate" type="date" class="form-control" />
                    </div>

                    
                </div>
            </div>

            <!-- Footer Save/Update -->
            <div class="card-footer d-flex justify-content-end gap-2">
                <a href="@Url.Action("Index")" class="btn btn-secondary px-4">
                    <i class="fas fa-arrow-left me-1"></i> Back
                </a>

                <button type="submit" class="btn btn-success">
                    <i class="bi bi-save me-1"></i> Save
                </button>
            </div>
        </form>
    </div>
</div>

<!-- ================= Script for Married Toggle ================= -->
@section Scripts {
    <script>
        $(document).ready(function () {
            function toggleSpouseFields() {
                if ($('#IsMarried').is(':checked')) {
                    $('.spouse-fields').show();
                } else {
                    $('.spouse-fields').hide();
                    $('.spouse-fields input').val('');
                }
            }

            toggleSpouseFields(); // initial check
            $('#IsMarried').change(toggleSpouseFields);
        });
    </script>
}