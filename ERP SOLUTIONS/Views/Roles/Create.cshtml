@using ERP_SOLUTIONS.Models.Entities
@model Role

@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewBag.Title = "Dashboard";
}

<style>

    /* Form Card */
    .form-card {
        width: 100%;
        max-width: 520px;
        border-radius: 16px;
        overflow: hidden;
        border: 1px solid #e3e6f0;
    }

        /* Card header accent line */
        .form-card .card-header {
            border-bottom: 2px solid #eef1ff;
        }

    /* Input focus effect */
    .form-control:focus {
        border-color: #4e73df;
        box-shadow: 0 0 0 0.15rem rgba(78, 115, 223, 0.25);
    }

    /* Input group icon styling */
    .input-group-text {
        border: none;
        border-right: 1px solid #e3e6f0;
    }

    /* Button hover */
    .btn-primary {
        background: linear-gradient(45deg, #4e73df, #224abe);
        border: none;
    }

        .btn-primary:hover {
            background: linear-gradient(45deg, #3b5bcc, #1b3a99);
        }

    /* Background subtle */
    body {
        background-color: #f8f9fc;
    }

</style>

<div class="container-fluid mt-4">

    <!-- Centered Card Wrapper -->
    <div class="d-flex justify-content-center">

        <!-- Card -->
        <div class="card form-card shadow-lg border-0 rounded-4">

            <!-- Card Header -->
            <div class="mb-4">
                <h3 class="fw-bold mb-1 text-dark">
                    <i class="fas fa-user-shield text-primary me-2"></i>
                    Create Role
                </h3>
                <small class="text-muted">Add a new role to the system</small>
            </div>

            <!-- Card Body -->
            <div class="card-body p-4">

                <form asp-action="Create" method="post">

                    <!-- Validation -->
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2"></div>

                    <!-- Role Name -->
                    <div class="mb-4">
                        <label asp-for="RoleName" class="form-label fw-semibold">
                            Role Name
                        </label>

                        <div class="input-group">
                            <span class="input-group-text bg-light">
                                <i class="fas fa-user-tag text-primary"></i>
                            </span>
                            <input asp-for="RoleName" class="form-control form-control-lg"
                                   placeholder="Enter role name..." />
                        </div>

                        <span asp-validation-for="RoleName" class="text-danger small"></span>
                    </div>

                    <!-- Role Description -->
                    <div class="mb-4">
                        <label asp-for="Description" class="form-label fw-semibold">
                            <i class="fas fa-align-left me-2 text-secondary"></i> Role Description </label>

                        <textarea asp-for="Description"
                                  class="form-control"
                                  rows="3"
                                  placeholder="Enter role description..."></textarea>

                        <span asp-validation-for="Description" class="text-danger small"></span>
                    </div>

                    <!-- Buttons -->
                    <div class="d-flex justify-content-between align-items-center mt-4">

                        <a asp-action="Index" class="btn btn-outline-secondary rounded-pill px-4">
                            <i class="fas fa-arrow-left me-2"></i> Back
                        </a>

                        <button type="submit" class="btn btn-primary rounded-pill px-4 shadow-sm">
                            <i class="fas fa-save me-2"></i> Save Role
                        </button>

                    </div>

                </form>

            </div>
        </div>
    </div>
</div>


