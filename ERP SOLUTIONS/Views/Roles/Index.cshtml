@using ERP_SOLUTIONS.Models.Entities
@model IEnumerable<Role>

@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewBag.Title = "Dashboard";
}

<style>
    .card {
        border-radius: 12px;
    }

    .btn {
        border-radius: 8px;
    }

    .table td, .table th {
        vertical-align: middle;
    }

    .table {
    border: 1px solid #e3e6f0;
    border-radius: 10px;
    overflow: hidden;
}

    .custom-header th {
        background: linear-gradient(45deg, #4e73df, #224abe) !important;
        color: #fff !important;
        font-weight: 600;
        letter-spacing: 0.5px;
        border: none !important;
    }

    /* Row borders */
    .table tbody tr {
        border-bottom: 1px solid #eef1f7;
    }

    /* Last row remove border */
    .table tbody tr:last-child {
        border-bottom: none;
    }
.
    /* Row hover effect */
    .role-row {
        transition: all 0.2s ease-in-out;
    }

    .role-row:hover {
        background-color: #f8f9fa;
        transform: scale(1.005);
    }

    /* Icon circle */
    .icon-circle {
        width: 36px;
        height: 36px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    /* Card enhancement */
    .card {
        overflow: hidden;
    }

    /* Table header styling */
    thead th {
        font-weight: 600;
        letter-spacing: 0.5px;
    }

    /* Badge subtle colors (Bootstrap 5.3+) fallback */
    .bg-success-subtle {
        background-color: #d1e7dd;
    }

    .bg-danger-subtle {
        background-color: #f8d7da;
    }
</style>

<div class="container-fluid mt-4">

    <div class="row justify-content-center">
        <div class="col-lg-8 col-md-10">

            <div class="card border-0 shadow-sm rounded-3">
                <div class="card-body p-0">

                    <!-- Your table stays same -->
                    <!-- Header -->
                    <div class="d-flex justify-content-between align-items-center mb-4">
                        <div>
                            <h3 class="fw-bold mb-0">
                                <i class="fas fa-user-shield text-primary me-2"></i>
                                Roles Management
                                <span class="badge bg-primary ms-2">@Model.Count()</span>
                            </h3>
                            <small class="text-muted">Manage system roles and permissions</small>
                        </div>
                        <a asp-controller="Roles" asp-action="Create" class="btn btn-success shadow-sm">
                            <i class="fas fa-plus me-2"></i> Add Role
                        </a>
                    </div>

                    <!-- Search -->
                    <div class="mb-3">
                        <input type="text" id="searchBox" class="form-control w-25"
                               placeholder="🔍 Search roles..." />
                    </div>

                    <!-- Card -->
                    <div class="card border-0 shadow-lg rounded-4">

                        <div class="card-body p-0">

                            <table class="table table-hover align-middle mb-0" id="rolesTable">
                                <thead class="custom-header">
                                    <tr class="small text-muted">
                                        <th class="ps-4">#</th>
                                        <th>Role</th>
                                        <th>Status</th>
                                        <th class="text-end pe-4">Actions</th>
                                    </tr>
                                </thead>

                                <tbody>
                                    @if (!Model.Any())
                                    {
                                        <tr>
                                            <td colspan="4" class="text-center py-5 text-muted">
                                                <i class="fas fa-info-circle fa-lg me-2"></i>
                                                No roles found
                                            </td>
                                        </tr>
                                    }
                                    else
                                    {
                                        int count = 1;
                                        foreach (var role in Model)
                                        {
                                            <tr class="role-row">
                                                <td class="ps-4 text-muted">@count</td>

                                                <!-- Role Name -->
                                                <td>
                                                    <div class="d-flex align-items-center">
                                                        <div class="icon-circle bg-light text-primary me-3">
                                                            <i class="fas fa-user-tag"></i>
                                                        </div>
                                                        <span class="fw-semibold">@role.RoleName</span>
                                                    </div>
                                                </td>

                                                <!-- Status -->
                                                <td>
                                                    @if (role.IsActive)
                                                    {
                                                        <span class="badge bg-success-subtle text-success px-3 py-2">
                                                            Active
                                                        </span>
                                                    }
                                                    else
                                                    {
                                                        <span class="badge bg-danger-subtle text-danger px-3 py-2">
                                                            Inactive
                                                        </span>
                                                    }
                                                </td>

                                                <!-- Actions -->
                                                <td class="text-end pe-4">
                                                    <a asp-action="Edit" asp-route-id="@role.RoleID"
                                                       class="btn btn-sm btn-outline-primary me-2 rounded-pill">
                                                        <i class="fas fa-edit me-1"></i> Edit
                                                    </a>

                                                    <a asp-action="Delete" asp-route-id="@role.RoleID"
                                                       class="btn btn-sm btn-outline-danger rounded-pill"
                                                       onclick="return confirm('Delete this role?');">
                                                        <i class="fas fa-trash me-1"></i> Delete
                                                    </a>
                                                </td>
                                            </tr>

                                            count++;
                                        }
                                    }
                                </tbody>
                            </table>

                        </div>
                    </div>
                
                
                </div>
            </div>

        </div>
    </div>

</div>

<script>

     document.getElementById("searchBox").addEventListener("keyup", function () {
        let value = this.value.toLowerCase();
        let rows = document.querySelectorAll("#rolesTable tbody tr");

        rows.forEach(row => {
            let text = row.innerText.toLowerCase();
            row.style.display = text.includes(value) ? "" : "none";
        });
    });

</script>