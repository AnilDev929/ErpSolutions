@using ERP_SOLUTIONS.Models.Entities
@model Role

@{
    ViewData["Title"] = "Edit Role";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>

    /* Card */
    .form-card {
        width: 100%;
        max-width: 520px;
        border-radius: 16px;
        border: 1px solid #e3e6f0;
        overflow: hidden;
    }

        /* Header */
        .form-card .card-header {
            border-bottom: 2px solid #e8edff;
        }

    /* Inputs (Soft Blue Focus) */
    .form-control:focus {
        border-color: #4e73df;
        box-shadow: 0 0 0 0.15rem rgba(78, 115, 223, 0.25);
    }

    /* Buttons (Soft Blue Gradient) */
    .btn-warning {
        background: linear-gradient(45deg, #4e73df, #6c8cff);
        border: none;
        color: #fff;
    }

    .btn-warning:hover {
        background: linear-gradient(45deg, #3b5bcc, #5a78e0);
    }

    /* Toggle switch */
    .form-check-input {
        width: 2.5em;
        height: 1.3em;
        cursor: pointer;
    }

    /* Optional: Active toggle color */
    .form-check-input:checked {
        background-color: #4e73df;
        border-color: #4e73df;
    }
</style>

<div class="container-fluid mt-4">

    <!-- Centered Card -->
    <div class="d-flex justify-content-center">

        <div class="card form-card shadow-lg border-0 rounded-4">

            <!-- Card Header -->
            <div class="card-header bg-white border-0 py-3 px-4">
                <h5 class="mb-0 fw-semibold text-primary">
                    <i class="fas fa-user-edit text-primary me-2"></i> Edit Role Information
                </h5>
                <small class="text-muted">Update role details</small>
            </div>

            <!-- Card Body -->
            <div class="card-body p-4">

                <form asp-action="Edit" method="post">

                    <input type="hidden" asp-for="RoleID" />

                    <!-- Validation -->
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2"></div>

                    <!-- Role Name -->
                    <div class="mb-4">
                        <label asp-for="RoleName" class="form-label fw-semibold"></label>

                        <div class="input-group">
                            <span class="input-group-text bg-light">
                                <i class="fas fa-user-tag text-primary"></i>
                            </span>
                            <input asp-for="RoleName" class="form-control form-control-lg" />
                        </div>

                        <span asp-validation-for="RoleName" class="text-danger small"></span>
                    </div>

                    <!-- Description -->
                    <div class="mb-4">
                        <label asp-for="Description" class="form-label fw-semibold">
                            <i class="fas fa-align-left me-2 text-secondary"></i> Role Description
                        </label>
                        <textarea asp-for="Description"
                                  class="form-control"
                                  rows="3"></textarea>

                        <span asp-validation-for="Description" class="text-danger small"></span>
                    </div>

                    <!-- Active Toggle -->
                    <div class="mb-4">
                        <label class="form-label fw-semibold d-block">Status</label>

                        <div class="form-check form-switch">
                            <input asp-for="IsActive" class="form-check-input" type="checkbox" />
                            <label class="form-check-label ms-2">
                                @(Model.IsActive ? "Active" : "Inactive")
                            </label>
                        </div>
                    </div>

                    <!-- Buttons -->
                    <div class="d-flex justify-content-between align-items-center mt-4">

                        <a asp-action="Index" class="btn btn-outline-secondary rounded-pill px-4">
                            <i class="fas fa-arrow-left me-2"></i> Back
                        </a>

                        <button type="submit" class="btn btn-warning rounded-pill px-4 shadow-sm">
                            <i class="fas fa-save me-2"></i> Update Role
                        </button>

                    </div>

                </form>

            </div>
        </div>
    </div>
</div>
