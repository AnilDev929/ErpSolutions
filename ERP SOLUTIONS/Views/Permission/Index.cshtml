@using ERP_SOLUTIONS.Models.Entities
@using ERP_SOLUTIONS.Models.ViewModels
@model RolePermissionViewModel

@{
    ViewData["Title"] = "Role Permissions";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var roles = ViewBag.Roles as List<Role>;
}

@* <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons/font/bootstrap-icons.css" rel="stylesheet" /> *@

<style>
    .card {
        border-radius: 12px;
        box-shadow: 0 4px 10px rgba(0,0,0,0.05);
    }

    /* Make checkbox border more visible */
    .form-check-input {
        width: 20px; /* bigger size */
        height: 20px;
        border: 2px solid #0d6efd; /* blue border */
        background-color: #fff;
    }

        /* Checked state color */
        .form-check-input:checked {
            background-color: #0d6efd; /* blue background */
            border-color: #0d6efd;
        }

</style>


<div class="container mt-4">
    
    <!-- 🔷 HEADER -->
    <div class="p-4 mb-4 rounded bg-light border shadow-sm">
        <div class="d-flex align-items-center">
            <div class="me-3 fs-1 text-primary">
                <i class="bi bi-shield-lock-fill"></i>
            </div>
            <div>
                <h3 class="mb-1">Role Permission Management</h3>
                <p class="text-muted mb-0">
                    Assign access rights to different roles. Control what each role can view, create, edit, or delete across system pages.
                </p>
            </div>
        </div>
    </div>

    <!-- 🔽 ROLE SELECT -->
    <div class="card shadow-sm mb-4">
        <div class="card-body d-flex align-items-center justify-content-between">

            <div class="d-flex align-items-center gap-3">
                <i class="bi bi-people-fill fs-4 text-secondary"></i>

                <div>
                    <label class="form-label fw-bold mb-0">Select Role</label>
                    <small class="text-muted d-block">Choose a role to manage its permissions</small>
                </div>
            </div>

            <form method="get" class="d-flex">
                <select name="roleId" class="form-select" onchange="this.form.submit()">
                    <option value="">-- Select Role --</option>
                    @foreach (var role in roles)
                    {
                        <option value="@role.RoleID" selected="@(role.RoleID == Model.RoleId)">
                            @role.RoleName
                        </option>
                    }
                </select>
            </form>

        </div>
    </div>

    @* IMPROVED UI (Accordion + Live Stats) *@

    @if (Model.RoleId != 0)
    {
        <form method="post" asp-action="Save">
            <input type="hidden" asp-for="RoleId" />

            <!-- 🔢 SUMMARY BAR -->
            <div class="d-flex gap-3 mb-3">

                <div class="badge bg-dark p-3">
                    <i class="bi bi-files"></i> Total:
                    <span id="totalCount">@Model.Sections.Sum(s => s.Items.Count)</span>
                </div>

                <div class="badge bg-success p-3">
                    <i class="bi bi-check-circle"></i> Assigned:
                    <span id="assignedCount">0</span>
                </div>

                <div class="badge bg-danger p-3">
                    <i class="bi bi-x-circle"></i> Unassigned:
                    <span id="unassignedCount">0</span>
                </div>

            </div>

            <!-- 📂 ACCORDION -->
            <div class="accordion" id="permissionAccordion">

                @for (int s = 0; s < Model.Sections.Count; s++)
                {
                    var _section = Model.Sections[s];
                    var collapseId = $"section_{s}";   // ✅ unique id

                    <div class="accordion-item mb-2 shadow-sm">

                        <!-- SECTION HEADER -->
                        <h2 class="accordion-header" id="heading_@s">
                            <button class="accordion-button collapsed d-flex justify-content-between align-items-center"
                                    type="button"
                                    data-bs-toggle="collapse"
                                    data-bs-target="#@collapseId"
                                    aria-expanded="false"
                                    aria-controls="@collapseId">

                                <span>
                                    <i class="bi bi-folder-fill text-primary"></i>
                                    <strong>@_section.SectionTitle</strong>
                                </span>

                                <!-- Select All -->
                                <input type="checkbox"
                                       class="form-check-input ms-3 select-all"
                                       onclick="event.stopPropagation(); onchange="event.stopPropagation();"" />
                            </button>
                        </h2>

                        <!-- SECTION BODY -->
                        <div id="@collapseId"
                             class="accordion-collapse collapse"
                             aria-labelledby="heading_@s"
                             data-bs-parent="#permissionAccordion">

                            <div class="accordion-body">

                                @for (int i = 0; i < _section.Items.Count; i++)
                                {
                                    <div class="d-flex justify-content-between align-items-center border-bottom py-2">

                                        <div>
                                            <i class="bi bi-file-earmark text-muted"></i>
                                            @_section.Items[i].MenuTitle
                                        </div>

                                        <div class="d-flex gap-3">

                                            <div class="form-check form-switch">
                                                <input class="form-check-input page-checkbox"
                                                       type="checkbox"
                                                       asp-for="Sections[s].Items[i].CanView" />
                                                <label class="form-check-label small">View</label>
                                            </div>

                                            <div class="form-check form-switch">
                                                <input class="form-check-input"
                                                       type="checkbox"
                                                       asp-for="Sections[s].Items[i].CanCreate" />
                                                <label class="form-check-label small">Create</label>
                                            </div>

                                            <div class="form-check form-switch">
                                                <input class="form-check-input"
                                                       type="checkbox"
                                                       asp-for="Sections[s].Items[i].CanEdit" />
                                                <label class="form-check-label small">Edit</label>
                                            </div>

                                            <div class="form-check form-switch">
                                                <input class="form-check-input"
                                                       type="checkbox"
                                                       asp-for="Sections[s].Items[i].CanDelete" />
                                                <label class="form-check-label small">Delete</label>
                                            </div>

                                        </div>

                                        <input type="hidden" asp-for="Sections[s].Items[i].MenuItemId" />

                                    </div>
                                }

                            </div>
                        </div>
                    </div>
                }

            </div>

            <!-- SAVE -->
            <div class="text-end mt-3">
                <button class="btn btn-success px-4">
                    <i class="bi bi-save"></i> Save Changes
                </button>
            </div>

        </form>
    }
    
</div>

<script>

    function updateCounts() {
        let all = document.querySelectorAll('.page-checkbox');
        let checked = document.querySelectorAll('.page-checkbox:checked');

        let total = all.length;
        let assigned = checked.length;
        let unassigned = total - assigned;

        document.getElementById('assignedCount').innerText = assigned;
        document.getElementById('unassignedCount').innerText = unassigned;
    }

    @* Initial load *@
    updateCounts();

    @* On change *@
    document.querySelectorAll('.page-checkbox').forEach(cb => {
        cb.addEventListener('change', updateCounts);
    });

    @* Select All per section *@
    document.querySelectorAll('.select-all').forEach(selectAll => {
        selectAll.addEventListener('change', function () {
            let body = this.closest('.accordion-item');
            let checkboxes = body.querySelectorAll('.page-checkbox');

            checkboxes.forEach(cb => cb.checked = this.checked);
            updateCounts();
        });
    });


   @*  🔁 Sync Select-All based on children *@
   @*  function syncSelectAll(section) {
        let allCheckboxes = section.querySelectorAll('.page-checkbox');
        let checkedCheckboxes = section.querySelectorAll('.page-checkbox:checked');
        let selectAll = section.querySelector('.select-all');

        selectAll.checked = allCheckboxes.length === checkedCheckboxes.length;
    } *@

    @*  // 🔐 Permission inheritance logic
     function handlePermissionChange(row) {
         let view = row.querySelector('input[name*="CanView"]');
         let create = row.querySelector('input[name*="CanCreate"]');
         let edit = row.querySelector('input[name*="CanEdit"]');
         let del = row.querySelector('input[name*="CanDelete"]');

         // If any of Create/Edit/Delete checked → View must be checked
         if (create.checked || edit.checked || del.checked) {
             view.checked = true;
         }

         // If View unchecked → disable others
         if (!view.checked) {
             create.checked = false;
             edit.checked = false;
             del.checked = false;
         }
     } *@

@* 
      // 🚀 INIT
     document.querySelectorAll('.accordion-item').forEach(section => {

         let rows = section.querySelectorAll('.d-flex.justify-content-between');

         rows.forEach(row => {
             let inputs = row.querySelectorAll('input[type="checkbox"]');

             inputs.forEach(input => {
                 input.addEventListener('change', function () {

                     // Apply permission rules
                     handlePermissionChange(row);

                     // Update select-all
                     syncSelectAll(section);

                     // Update counts
                     updateCounts();
                 });
             });
         });

         // Select-All click
         let selectAll = section.querySelector('.select-all');

         selectAll.addEventListener('change', function () {
             let checkboxes = section.querySelectorAll('.page-checkbox');

             checkboxes.forEach(cb => {
                 cb.checked = this.checked;

                 let row = cb.closest('.d-flex');
                 handlePermissionChange(row);
             });

             updateCounts();
         });

         // Initial sync
         syncSelectAll(section);
     });

     // Initial count load
     updateCounts();
 *@
</script>