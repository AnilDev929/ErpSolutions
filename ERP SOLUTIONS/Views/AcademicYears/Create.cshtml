@using ERP_SOLUTIONS.Models.Entities
@model AcademicYear

@{
    ViewData["Title"] = "Academic Years";
    Layout = "~/Views/Shared/_Layout.cshtml";
}


<div class="container mt-5">

    <div class="row justify-content-center">

        <!-- Card Header -->
        <div class="mb-4">
            <h4 class="mb-4 text-primary"><i class="fa fa-calendar-alt me-2"></i>Create Academic Year</h4>
            <small class="text-muted">Add a new Academic Year to the system</small>
        </div>

        <!-- Card Body -->
        <div class="card-body p-4">
            <form asp-action="Create" method="post" class="card p-4 shadow-sm">

                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="row">

                    <!-- Year Name -->
                    <div class="col-md-6 mb-3">
                        <label asp-for="YearName" class="form-label"></label>
                        <div class="input-group custom-input">
                            <span class="input-group-text"><i class="fa fa-graduation-cap"></i></span>
                            <input asp-for="YearName" class="form-control" placeholder="2025-2026" />
                        </div>
                        <span asp-validation-for="YearName" class="text-danger small"></span>
                    </div>

                    <!-- Active Toggle -->
                    <div class="col-md-6 mb-3 d-flex align-items-center">
                        <div class="form-check form-switch mt-2">
                            <input asp-for="IsActive" class="form-check-input" />
                            <label asp-for="IsActive" class="form-check-label ms-2">Active</label>
                        </div>
                    </div>

                    <!-- Start Date -->
                    <div class="col-md-6 mb-3">
                        <label asp-for="YearStart" class="form-label"></label>
                        <div class="input-group custom-input">
                            <span class="input-group-text"><i class="fa fa-play-circle"></i></span>
                            <input asp-for="YearStart" type="date" class="form-control" />
                        </div>
                        <span asp-validation-for="YearStart" class="text-danger small"></span>
                    </div>

                    <!-- End Date -->
                    <div class="col-md-6 mb-3">
                        <label asp-for="YearEnd" class="form-label"></label>
                        <div class="input-group custom-input">
                            <span class="input-group-text"><i class="fa fa-stop-circle"></i></span>
                            <input asp-for="YearEnd" type="date" class="form-control" />
                        </div>
                        <span asp-validation-for="YearEnd" class="text-danger small"></span>
                    </div>

                </div>

                <div class="d-flex gap-2 mt-3">
                    <button class="btn btn-primary px-4">
                        <i class="fa fa-save me-1"></i> Save
                    </button>
                    <a asp-action="Index" class="btn btn-outline-secondary px-4">
                        <i class="fa fa-arrow-left me-1"></i> Back
                    </a>
                </div>
            </form>
        </div>

    </div>

    
</div>

