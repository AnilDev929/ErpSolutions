@using ERP_SOLUTIONS.Models.Entities
@model IEnumerable<AcademicYear>
@{
    ViewData["Title"] = "Academic Years";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container mt-4">

    <div class="card shadow-sm p-4">

        <div class="d-flex justify-content-between mb-3">
            <h3 class="mb-3 text-primary">
                <i class="fa fa-list"></i> Academic Years
            </h3>
            <a asp-action="Create" class="btn btn-success mb-3">
                <i class="fa fa-plus"></i> Add New
            </a>
        </div>

        <!-- Filters -->
        <form method="get" class="row mb-3">
            <div class="col-md-4">
                <input type="text" name="search" class="form-control"
                       placeholder="Search year..." value="@Context.Request.Query["search"]" />
            </div>

            <div class="col-md-3">
                <select name="status" class="form-select">
                    <option value="">All</option>
                    <option value="true">Active</option>
                    <option value="false">Inactive</option>
                </select>
            </div>

            <div class="col-md-3">
                <button class="btn btn-outline-primary">Filter</button>
                <a asp-action="Index" class="btn btn-outline-secondary">Reset</a>
            </div>
        </form>

        <!-- Table -->
        @if (!Model.Any())
        {
            <div class="text-center text-muted py-4">
                No records found
            </div>
        }
        else
        {
            <table class="table table-hover">
                <thead class="table-light">
                    <tr>
                        <th>Year</th>
                        <th>Start</th>
                        <th>End</th>
                        <th>Status</th>
                        <th class="text-end">Action</th>
                    </tr>
                </thead>

                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr class="@(item.IsActive ? "table-success" : "")">
                            <td>@item.YearName</td>
                            <td>@item.YearStart.ToShortDateString()</td>
                            <td>@item.YearEnd.ToShortDateString()</td>

                            <td>
                                @if (item.IsActive)
                                {
                                    <span class="badge bg-success">Active</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">Inactive</span>
                                }
                            </td>

                            <td class="text-end">
                                <a asp-action="Edit" asp-route-id="@item.AcademicYearID"
                                   class="btn btn-sm btn-primary"><i class="fa fa-edit"></i></a>

                                <a asp-action="Delete" asp-route-id="@item.AcademicYearID"
                                   class="btn btn-sm btn-danger"
                                   onclick="return confirm('Are you sure?')">
                                    <i class="fa fa-trash"></i>
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }

    </div>

</div>


