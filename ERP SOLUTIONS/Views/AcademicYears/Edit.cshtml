@using ERP_SOLUTIONS.Models.Entities
@model AcademicYear

@{
    ViewData["Title"] = "Edit Academic Years";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid mt-4">

    <div class="d-flex justify-content-center">
        <div class="card shadow-sm" style="max-width: 700px; width: 100%;">

            <!-- Header -->
            <div class="card-header bg-white border-bottom">
                <h5 class="mb-0 fw-semibold text-primary">
                    <i class="fas fa-calendar-alt me-2"></i>
                    Edit Academic Year
                </h5>
                <small class="text-muted">Update academic year details</small>
            </div>

            <!-- Body -->
            <div class="card-body">

                <form asp-action="Edit" method="post">

                    <input type="hidden" asp-for="AcademicYearID" />

                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="row">

                        <!-- Year Name -->
                        <div class="col-md-6 mb-3">
                            <label asp-for="YearName" class="form-label"></label>
                            <div class="input-group">
                                <span class="input-group-text">
                                    <i class="fas fa-calendar"></i>
                                </span>
                                <input asp-for="YearName" class="form-control" placeholder="e.g. 2025-2026" />
                            </div>
                        </div>

                        <!-- Active Switch -->
                        <div class="col-md-6 mb-3 d-flex align-items-center">
                            <div class="form-check form-switch mt-3">
                                <input asp-for="IsActive" class="form-check-input" />
                                <label asp-for="IsActive" class="form-check-label">
                                    Active
                                </label>
                            </div>
                        </div>

                    </div>

                    <!-- Section Divider -->
                    <hr />
                    <h6 class="text-muted mb-3">
                        <i class="fas fa-clock me-1"></i> Duration
                    </h6>

                    <div class="row">
                        <!-- Start Date -->
                        <div class="col-md-6 mb-3">
                            <label asp-for="YearStart" class="form-label"></label>
                            <div class="input-group">
                                <span class="input-group-text">
                                    <i class="fas fa-calendar-plus"></i>
                                </span>
                                <input asp-for="YearStart" type="date" class="form-control" />
                            </div>
                        </div>

                        <!-- End Date -->
                        <div class="col-md-6 mb-3">
                            <label asp-for="YearEnd" class="form-label"></label>
                            <div class="input-group">
                                <span class="input-group-text">
                                    <i class="fas fa-calendar-check"></i>
                                </span>
                                <input asp-for="YearEnd" type="date" class="form-control" />
                            </div>
                        </div>
                    </div>

                    <!-- Action Buttons -->
                    <div class="d-flex justify-content-between align-items-center mt-4">

                        <a asp-action="Index" class="btn btn-outline-secondary rounded-pill px-4">
                            <i class="fas fa-arrow-left me-2"></i> Back
                        </a>

                        <button type="submit" class="btn btn-warning rounded-pill px-4 shadow-sm">
                            <i class="fas fa-save me-2"></i> Update
                        </button>

                    </div>

                </form>

            </div>
        </div>
    </div>

</div>

