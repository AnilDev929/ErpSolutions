@using ERP_SOLUTIONS.Models.Entities
@model List<MenuSection>

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons/font/bootstrap-icons.css" rel="stylesheet" />
<link href="~/css/homepage.css" rel="stylesheet" />

<!-- ===== HEADER ===== -->
<nav class="navbar navbar-expand-lg navbar-light bg-white sticky-top">
    <div class="container">
        <a class="navbar-brand fw-bold" href="#">School ERP</a>

        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navMenu">
            <span class="navbar-toggler-icon"></span>
        </button>

        <div class="collapse navbar-collapse" id="navMenu">
            <ul class="navbar-nav ms-auto">
                <li class="nav-item"><a class="nav-link active" href="#">Home</a></li>
                <li class="nav-item"><a class="nav-link" href="#">About</a></li>
                <li class="nav-item"><a class="nav-link" href="#">Contact</a></li>
                <li class="nav-item"><a class="nav-link" href="#">Trial</a></li>
                <li class="nav-item">
                    @* <a class="btn btn-primary ms-2 px-3" href="#">Sign In</a> *@
                    <a asp-controller="Account" asp-action="LogIn" class="btn btn-primary ms-2 px-3">Sign In</a>
                </li>
            </ul>
        </div>
    </div>
</nav>

<!-- ===== BODY ===== -->
<div class="container mt-4">

    @foreach (var sec in Model)
    {
        <div class="mb-5">

            <div class="section-header">
                <div class="section-icon @sec.Color">
                    <i class="bi @sec.Icon"></i>
                </div>
                <div>
                    <h4 class="mb-0">@sec.Title</h4>
                    <small class="text-muted">@sec.Subtitle</small>
                </div>
            </div>

            <div class="row g-3 mt-2">
                @foreach (var item in sec.Items)
                {
                    <div class="col-md-3">
                        <a href="@item.Url" style="text-decoration:none; color:inherit;">
                            <div class="card-box">
                                <div class="card-icon">
                                    <i class="bi @item.Icon"></i>
                                </div>
                                <h5>@item.Title</h5>
                                <p class="card-desc">@item.Description</p>
                            </div>
                        </a>
                    </div>
                }
            </div>

        </div>
    }

</div>

<!-- ===== FOOTER ===== -->
<footer class="footer">
    <div class="container">
        <div class="row align-items-center">

            <!-- LEFT: Social Media -->
            <div class="col-md-6 text-center text-md-start mb-2 mb-md-0">
                <a href="#" class="me-3 text-light"><i class="bi bi-twitter fs-5"></i></a>
                <a href="#" class="me-3 text-light"><i class="bi bi-facebook fs-5"></i></a>
                <a href="#" class="me-3 text-light"><i class="bi bi-linkedin fs-5"></i></a>
                <a href="#" class="text-light"><i class="bi bi-instagram fs-5"></i></a>
            </div>

            <!-- RIGHT: Contact Info -->
            <div class="col-md-6 text-center text-md-end">
                <div class="footer-contact">
                    <span class="me-3">
                        <i class="bi bi-envelope-fill me-1"></i> support@schoolerp.com
                    </span>
                    <span class="me-3">
                        <i class="bi bi-telephone-fill me-1"></i> +91 00000 11111
                    </span>
                    <span>
                        <i class="bi bi-geo-alt-fill me-1"></i> Odisha, India
                    </span>
                </div>
            </div>

        </div>

    </div>
</footer>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>