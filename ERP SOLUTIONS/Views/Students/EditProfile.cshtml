@using ERP_SOLUTIONS.Models.Entities
@model Student

@{
    ViewData["Title"] = "EditProfile";
    Layout = "~/Views/Shared/_Layout.cshtml";
}


<div class="container-fluid mt-4">

    <!-- Header -->
    <div class="mb-4">
        <h3 class="fw-bold mb-1 text-dark">
            <i class="fas fa-user-edit text-primary me-2"></i> Edit Profile
        </h3>
        <small class="text-muted">Update your profile information</small>
    </div>

    <!-- Card -->
    <div class="row justify-content-center">
        <div class="col-lg-8 col-md-10">
            <div class="card shadow-sm border-0 rounded-3 form-card">

                <!-- Card Header -->
                <div class="card-header bg-light py-3">
                    <h5 class="mb-0 text-primary"><i class="fas fa-id-badge me-2"></i> Profile Details</h5>
                </div>

                <!-- Card Body -->
                <div class="card-body p-4">
                    <form asp-action="EditProfile" method="post">
                        <input type="hidden" asp-for="StudentID" />

                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                        <!-- Full Name, Blood Group & Gender -->
                        <div class="row mb-3">
                            <div class="col-md-6">
                                <label asp-for="FullName" class="form-label fw-semibold">
                                    <i class="fas fa-user me-2 text-secondary"></i> Full Name
                                </label>
                                <input asp-for="FullName" class="form-control" placeholder="Enter full name..." />
                                <span asp-validation-for="FullName" class="text-danger small"></span>
                            </div>
                            <!-- Blood Group -->
                            <div class="col-md-3">
                                <label asp-for="BloodGroup" class="form-label fw-semibold">
                                    <i class="fas fa-tint me-2 text-secondary"></i> Blood Group
                                </label>
                                <select asp-for="BloodGroup" class="form-select">
                                    <option value="">Select blood group</option>
                                    <option>A+</option>
                                    <option>A-</option>
                                    <option>B+</option>
                                    <option>B-</option>
                                    <option>O+</option>
                                    <option>O-</option>
                                    <option>AB+</option>
                                    <option>AB-</option>
                                </select>
                                <span asp-validation-for="BloodGroup" class="text-danger small"></span>
                            </div>
                            <div class="col-md-3">
                                <label asp-for="Gender" class="form-label fw-semibold">
                                    <i class="fas fa-venus-mars me-2 text-secondary"></i> Gender
                                </label>
                                <select asp-for="Gender" class="form-select">
                                    <option value="">Select gender</option>
                                    <option>Male</option>
                                    <option>Female</option>
                                    <option>Other</option>
                                </select>
                                <span asp-validation-for="Gender" class="text-danger small"></span>
                            </div>
                        </div>

                        <!-- Mobile & Email -->
                        <div class="row mb-3">
                            <div class="col-md-6">
                                <label asp-for="MobileNumber" class="form-label fw-semibold">
                                    <i class="fas fa-phone me-2 text-secondary"></i> Mobile Number
                                </label>
                                <input asp-for="MobileNumber" class="form-control" placeholder="Enter mobile number..." />
                                <span asp-validation-for="MobileNumber" class="text-danger small"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="Email" class="form-label fw-semibold">
                                    <i class="fas fa-envelope me-2 text-secondary"></i> Email ID
                                </label>
                                <input asp-for="Email" class="form-control" placeholder="Enter email..." />
                                <span asp-validation-for="Email" class="text-danger small"></span>
                            </div>
                        </div>

                        <!-- Roll No & DOB -->
                        <div class="row mb-3">
                            <div class="col-md-6">
                                <label asp-for="RollNo" class="form-label fw-semibold">
                                    <i class="fas fa-id-card me-2 text-secondary"></i> Roll No
                                </label>
                                <input asp-for="RollNo" class="form-control" placeholder="Enter roll number..." readonly />
                            </div>
                            <div class="col-md-6">
                                <label asp-for="DateOfBirth" class="form-label fw-semibold">
                                    <i class="fas fa-calendar-alt me-2 text-secondary"></i> Date of Birth
                                </label>
                                <input asp-for="DateOfBirth" type="date" class="form-control" />
                                <span asp-validation-for="DateOfBirth" class="text-danger small"></span>
                            </div>
                        </div>

                        <!-- Date of Join & Address -->
                        <div class="row mb-3">
                            <div class="col-md-6">
                                <label asp-for="DateOfJoin" class="form-label fw-semibold">
                                    <i class="fas fa-calendar-check me-2 text-secondary"></i> Date of Join
                                </label>
                                <input asp-for="DateOfJoin" type="date" class="form-control" />
                                <span asp-validation-for="DateOfJoin" class="text-danger small"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="PermanentAddress" class="form-label fw-semibold">
                                    <i class="fas fa-map-marker-alt me-2 text-secondary"></i> Address
                                </label>
                                <textarea asp-for="PermanentAddress" class="form-control" rows="2" placeholder="Enter address..."></textarea>
                                <span asp-validation-for="PermanentAddress" class="text-danger small"></span>
                            </div>
                        </div>

                        <!-- Parent Info -->
                        <div class="row mb-3">
                            <div class="col-md-6">
                                <label asp-for="ParentName" class="form-label fw-semibold">
                                    <i class="fas fa-user-friends me-2 text-secondary"></i> Parent Name
                                </label>
                                <input asp-for="ParentName" class="form-control" placeholder="Enter parent name..." />
                                <span asp-validation-for="ParentName" class="text-danger small"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="ParentContact" class="form-label fw-semibold">
                                    <i class="fas fa-phone-alt me-2 text-secondary"></i> Parent Contact
                                </label>
                                <input asp-for="ParentContact" class="form-control" placeholder="Enter parent contact..." />
                                <span asp-validation-for="ParentContact" class="text-danger small"></span>
                            </div>
                        </div>

                        <!-- Buttons -->
                        <div class="d-flex justify-content-between mt-4">
                            <a asp-action="MyProfile" class="btn btn-light border">
                                <i class="fas fa-arrow-left me-2"></i> Cancel
                            </a>
                            <button type="submit" class="btn btn-primary">
                                <i class="fas fa-save me-2"></i> Save Profile
                            </button>
                        </div>

                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
