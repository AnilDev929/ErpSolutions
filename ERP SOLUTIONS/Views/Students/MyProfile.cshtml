@using ERP_SOLUTIONS.Models.Entities
@model Student

@{
    ViewData["Title"] = "My Profile";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    /* Card Styling */
    .form-card {
        border-radius: 16px !important;
        border: 1px solid #cfd8e3 !important;
        overflow: hidden;
        box-shadow: 0 4px 15px rgba(0, 0, 0, 0.08) !important;
        transition: transform 0.2s, box-shadow 0.2s;
    }

    /* Card Header */
    .card-header {
        background: linear-gradient(90deg, #eef2ff, #ffffff);
        border-bottom: 1px solid #d1d5db;
        font-weight: 600;
    }

    /* Labels & Info */
    label {
        font-size: 0.9rem;
    }
    /* Input Styling */
    .form-control {
        border-radius: 0 8px 8px 0;
        border: 1px solid #d1d5db;
    }

        .form-control.bg-light {
            background-color: #f8f9fc;
        }
    /* .form-control.bg-light {
        background-color: #f8f9fc;
        border: 1px solid #d1d5db;
        border-radius: 8px;
        padding: 0.5rem 0.75rem;
        height: auto;
    } */

    /* Input Group Icon */
    .input-group-text {
        background-color: #f8f9fc;
        border: 1px solid #d1d5db;
        border-radius: 8px 0 0 8px;
        color: #4e73df;
        min-width: 45px;
        justify-content: center;
    }

    /* Buttons */
    .btn-primary {
        background: linear-gradient(45deg, #4e73df, #6c8cff);
        border: none;
    }

        .btn-primary:hover {
            background: linear-gradient(45deg, #3b5bcc, #5a78e0);
        }
</style>

<div class="container-fluid mt-4">

    <!-- Header -->
    <div class="mb-4">
        <h3 class="fw-bold mb-1 text-dark">
            <i class="fas fa-user-circle text-primary me-2"></i>
            My Profile
        </h3>
        <small class="text-muted">View and manage your profile information</small>
    </div>

    <div class="row justify-content-center">
        <div class="col-lg-8 col-md-10">

            <div class="card shadow-sm border-0 rounded-3 form-card">

                <!-- Card Header -->
                <div class="card-header bg-light py-3">
                    <h5 class="mb-0 text-primary">
                        <i class="fas fa-id-badge me-2"></i>Profile Details
                    </h5>
                </div>

                <!-- Card Body -->
                <div class="card-body">

                    <!-- Row 1 -->
                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label class="fw-semibold text-secondary">Full Name</label>
                            <div class="input-group">
                                <span class="input-group-text"><i class="fas fa-user"></i></span>
                                <input asp-for="FullName" class="form-control" placeholder="Enter your name..." />
                            </div>
                        </div>

                        <div class="col-md-6">
                            <label class="fw-semibold text-secondary">Gender</label>
                            <div class="input-group">
                                <span class="input-group-text"><i class="fas fa-venus-mars"></i></span>
                                <input asp-for="Gender" class="form-control bg-light" />
                            </div>
                        </div>
                    </div>

                    <!-- Row 2 -->
                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label class="fw-semibold text-secondary">Mobile Number</label>
                            <div class="input-group">
                                <span class="input-group-text"><i class="fas fa-phone"></i></span>
                                <input asp-for="MobileNumber" class="form-control bg-light" />
                            </div>
                        </div>

                        <div class="col-md-6">
                            <label class="fw-semibold text-secondary">Email</label>
                            <div class="input-group">
                                <span class="input-group-text"><i class="fas fa-envelope"></i></span>
                                <input asp-for="Email" class="form-control bg-light" />
                            </div>
                        </div>
                    </div>

                    <!-- Row 3 -->
                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label class="fw-semibold text-secondary">Roll No</label>
                            <div class="input-group">
                                <span class="input-group-text"><i class="fas fa-id-card"></i></span>
                                <input asp-for="RollNo" class="form-control bg-light" />
                            </div>
                        </div>

                        <div class="col-md-6">
                            <label class="fw-semibold text-secondary">Date of Birth</label>
                            <div class="input-group">
                                <span class="input-group-text"><i class="fas fa-calendar-alt"></i></span>
                                <input asp-for="DateOfBirth" type="date" class="form-control bg-light" />
                            </div>
                        </div>
                    </div>

                    <!-- Row 4 -->
                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label class="fw-semibold text-secondary">Date of Join</label>
                            <div class="input-group">
                                <span class="input-group-text"><i class="fas fa-calendar-check"></i></span>
                                <input asp-for="DateOfJoin" type="date" class="form-control bg-light" />
                            </div>
                        </div>

                        <div class="col-md-6">
                            <label class="fw-semibold text-secondary">Address</label>
                            <div class="input-group">
                                <span class="input-group-text"><i class="fas fa-map-marker-alt"></i></span>
                                <input asp-for="PermanentAddress" class="form-control bg-light" />
                            </div>
                        </div>
                    </div>

                    <!-- Row 5 -->
                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label class="fw-semibold text-secondary">Parent Name</label>
                            <div class="input-group">
                                <span class="input-group-text"><i class="fas fa-user-friends"></i></span>
                                <input asp-for="ParentName" class="form-control bg-light" />
                            </div>
                        </div>

                        <div class="col-md-6">
                            <label class="fw-semibold text-secondary">Parent Contact</label>
                            <div class="input-group">
                                <span class="input-group-text"><i class="fas fa-phone-alt"></i></span>
                                <input asp-for="ParentContact" class="form-control bg-light" />
                            </div>
                        </div>
                    </div>

                    <!-- Button -->
                    <div class="text-end mt-4">
                        <a href="@Url.Action("EditProfile", "Account")"
                           class="btn btn-primary rounded-pill px-4 shadow-sm">
                            <i class="fas fa-edit me-2"></i> Edit Profile
                        </a>
                    </div>

                </div>
            </div>
        </div>
    </div>
</div>