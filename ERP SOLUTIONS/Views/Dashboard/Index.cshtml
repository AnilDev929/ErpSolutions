@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewBag.Title = "Dashboard";
}

<div class="container-fluid">
    <div class="row g-4">
        <!-- Students -->
        <div class="col-md-3">
            <div class="card dashboard-card text-white bg-primary" onclick="location.href='@Url.Action("Index", "Students")'">
                <div class="card-body">
                    <h5 class="card-title"><i class="fas fa-user-graduate"></i> Students</h5>
                    <p class="card-text display-4">450</p>
                </div>
            </div>
        </div>

        <!-- Teachers -->
        <div class="col-md-3">
            <div class="card dashboard-card text-white bg-success" onclick="location.href='@Url.Action("Index", "Teachers")'">
                <div class="card-body">
                    <h5 class="card-title"><i class="fas fa-chalkboard-teacher"></i> Teachers</h5>
                    <p class="card-text display-4">35</p>
                </div>
            </div>
        </div>

        <!-- Classes -->
        <div class="col-md-3">
            <div class="card dashboard-card text-white bg-warning" onclick="location.href='@Url.Action("Index", "Classes")'">
                <div class="card-body">
                    <h5 class="card-title"><i class="fas fa-school"></i> Classes</h5>
                    <p class="card-text display-4">12</p>
                </div>
            </div>
        </div>

        <!-- Exams -->
        <div class="col-md-3">
            <div class="card dashboard-card text-white bg-danger" onclick="location.href='@Url.Action("Index", "Exams")'">
                <div class="card-body">
                    <h5 class="card-title"><i class="fas fa-file-alt"></i> Exams</h5>
                    <p class="card-text display-4">5</p>
                </div>
            </div>
        </div>

        <!-- Fees -->
        <div class="col-md-3">
            <div class="card dashboard-card text-white bg-info" onclick="location.href='@Url.Action("Index", "Fees")'">
                <div class="card-body">
                    <h5 class="card-title"><i class="fas fa-wallet"></i> Fees Pending</h5>
                    <p class="card-text display-4">80</p>
                </div>
            </div>
        </div>
    </div>
</div>