@using ERP_SOLUTIONS.Models.Entities
@model List<DashboardSection>

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet"/>
<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons/font/bootstrap-icons.css" rel="stylesheet"/>

<style>
    body {
    background: #f8f9fc;
}

    /* ===== HEADER (Office Blue) ===== */
    .navbar {
        background: linear-gradient(90deg, #1f4e79, #2b6cb0);
    }

        .navbar .nav-link,
        .navbar .navbar-brand {
            color: #fff !important;
        }

            .navbar .nav-link:hover {
                color: #cfe2ff !important;
            }

        .navbar .btn {
            background: #ffffff;
            color: #1f4e79;
            border: none;
        }

            .navbar .btn:hover {
                background: #e2e6ea;
            }


.section-header {
    display: flex;
    align-items: center;
        margin-bottom: 15px;
        gap: 12px; /* 🔥 clean spacing */
        border-bottom: 1px solid #eee;
        padding-bottom: 10px;
}

    .mb-5 {
        margin-bottom: 3rem !important;
    }
.section-icon {
    width: 55px;
    height: 55px;
    border-radius: 14px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: white;
    font-size: 22px;
    margin-right: 15px;
}

.blue { background: linear-gradient(135deg,#4e73df,#224abe); }
.purple { background: linear-gradient(135deg,#7b2ff7,#9f44d3); }
.green { background: linear-gradient(135deg,#1cc88a,#13855c); }
.orange { background: linear-gradient(135deg,#f6c23e,#dda20a); }
.red { background: linear-gradient(135deg,#e74a3b,#be2617); }
.teal { background: linear-gradient(135deg,#20c997,#138d75); }
.dark { background: linear-gradient(135deg,#343a40,#000); }

    . /* ===== CARD ===== */
    .card-box {
        background: #fff;
        padding: 20px;
        border-radius: 14px;
        box-shadow: 0 4px 10px rgba(0,0,0,0.05);
        transition: 0.3s;
        cursor: pointer;
        height: 100%;
    }

.card-box:hover {
    transform: translateY(-5px);
}

.card-icon {
    width: 45px;
    height: 45px;
    border-radius: 10px;
    background: #4e73df;
    color: white;
    display:flex;
    align-items:center;
    justify-content:center;
    margin-bottom: 10px;
}

    /* ===== FOOTER ===== */
    .footer {
        background: #111;
        color: #ccc;
        padding: 20px 0;
    }

        .footer a {
            color: #ccc;
            margin-right: 15px;
        }

            .footer a:hover {
                color: #0d6efd; /* Bootstrap primary blue */
            }


    .footer-contact {
        color: #ddd;
        font-size: 14px;
        font-weight: 500; /* 🔥 better visibility */
    }

        .footer-contact i {
            color: #0d6efd; /* nice blue accent */
        }

        .footer-contact span {
            display: inline-block;
            margin-bottom: 5px;
        }

    /* MOBILE FIX */
    @@media (max-width: 768px) {
        .section-header h4
        {
            font-size: 18px;
        }

        .footer-contact span,
        .footer-contact a {
            display: block;
        }
    }

</style>


<!-- ===== HEADER ===== -->
<nav class="navbar navbar-expand-lg navbar-light bg-white sticky-top">
    <div class="container">
        <a class="navbar-brand fw-bold" href="#">School ERP</a>

        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navMenu">
            <span class="navbar-toggler-icon"></span>
        </button>

        <div class="collapse navbar-collapse" id="navMenu">
            <ul class="navbar-nav ms-auto">
                <li class="nav-item"><a class="nav-link active" href="#">Home</a></li>
                <li class="nav-item"><a class="nav-link" href="#">About</a></li>
                <li class="nav-item"><a class="nav-link" href="#">Contact</a></li>
                <li class="nav-item"><a class="nav-link" href="#">Trial</a></li>
                <li class="nav-item">
                    <a class="btn btn-primary ms-2 px-3" href="#">Sign In</a>
                </li>
            </ul>
        </div>
    </div>
</nav>

<!-- ===== BODY ===== -->
<div class="container mt-4">

    @foreach (var sec in Model)
    {
        <div class="mb-5">

            <div class="section-header">
                <div class="section-icon @sec.Color">
                    <i class="bi @sec.Icon"></i>
                </div>
                <div>
                        <h4 class="mb-0">@sec.Title</h4>
                        <small class="text-muted">@sec.Subtitle</small>
                </div>
            </div>

            <div class="row g-3 mt-2">
                    @foreach (var item in sec.Items)
                {
                    <div class="col-md-3">
                        <a href="@item.Url" style="text-decoration:none; color:inherit;">
                            <div class="card-box">
                                <div class="card-icon">
                                    <i class="bi @item.Icon"></i>
                                </div>
                                <h5>@item.Title</h5>
                                <p class="card-desc">@item.Description</p>
                            </div>
                        </a>
                    </div>
                }
            </div>

        </div>
    }

</div>

<!-- ===== FOOTER ===== -->
<footer class="footer">
    <div class="container">
        <div class="row align-items-center">

            <!-- LEFT: Social Media -->
            <div class="col-md-6 text-center text-md-start mb-2 mb-md-0">
                <a href="#" class="me-3 text-light"><i class="bi bi-twitter fs-5"></i></a>
                <a href="#" class="me-3 text-light"><i class="bi bi-facebook fs-5"></i></a>
                <a href="#" class="me-3 text-light"><i class="bi bi-linkedin fs-5"></i></a>
                <a href="#" class="text-light"><i class="bi bi-instagram fs-5"></i></a>
            </div>

            <!-- RIGHT: Contact Info -->
            <div class="col-md-6 text-center text-md-end">
                <div class="footer-contact">
                    <span class="me-3">
                        <i class="bi bi-envelope-fill me-1"></i> support@erp.com
                    </span>
                    <span class="me-3">
                        <i class="bi bi-telephone-fill me-1"></i> +91 98765 43210
                    </span>
                    <span>
                        <i class="bi bi-geo-alt-fill me-1"></i> Odisha, India
                    </span>
                </div>
            </div>

        </div>

    </div>
</footer>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>