@using ERP_SOLUTIONS.Models.ViewModels
@model HostelWithRoomsVM

@{
    ViewBag.Title = "Create Hostel";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container mt-5">

    <!-- Header & Add Button -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="text-primary">
                <i class="fas fa-chalkboard"></i> Hostel Management
            </h2>
            <small class="text-muted">Manage Hostels and Rooms provided by school</small>
        </div>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">@TempData["Success"]</div>
    }

    <form method="post" onsubmit="return validateForm();">
        @Html.AntiForgeryToken()

        <!-- Hostel Section -->
        <div class="card mb-3">
            <div class="card-header">Hostel Information</div>
            <div class="card-body row">
                <div class="col-md-4">
                    <label>Hostel Name</label>
                    <input name="Hostel.HostelName" class="form-control" required />
                </div>

                <div class="col-md-4">
                    <label>Location</label>
                    <input name="Hostel.Location" class="form-control" />
                </div>

                <div class="col-md-4">
                    <label>Description</label>
                    <input name="Hostel.Description" class="form-control" />
                </div>
            </div>
        </div>

        <!-- Rooms Section -->
        <div class="card">
            <div class="card-header d-flex justify-content-between">
                <span>Rooms</span>
                <button type="button" class="btn btn-primary btn-sm" onclick="addRoom()">+ Add Room</button>
            </div>

            <div class="card-body">
                <table class="table table-bordered" id="roomTable">
                    <thead>
                        <tr>
                            <th>Room No</th>
                            <th>Capacity</th>
                            <th>Type</th>
                            <th>Fee</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody></tbody>
                </table>
            </div>
        </div>

        <br />
        <button type="submit" class="btn btn-success">Save Hostel</button>
    </form>

</div>





<!-- JavaScript -->
<script>
    let roomIndex = 0;

    // Add Room Row
    function addRoom() {
        let table = document.querySelector("#roomTable tbody");

        let row = `
        <tr>
            <td><input name="Rooms[${roomIndex}].RoomNumber" class="form-control" required /></td>
            <td><input name="Rooms[${roomIndex}].Capacity" type="number" class="form-control" required /></td>
            <td>
                <select name="Rooms[${roomIndex}].RoomType" class="form-control">
                    <option>AC</option>
                    <option>Non-AC</option>
                    <option>Sharing</option>
                </select>
            </td>
            <td><input name="Rooms[${roomIndex}].Fee" type="number" class="form-control" required /></td>
            <td><button type="button" class="btn btn-danger btn-sm" onclick="removeRow(this)">✖</button></td>
        </tr>`;

        table.insertAdjacentHTML('beforeend', row);
        roomIndex++;
    }

    // Remove Row
    function removeRow(btn) {
        btn.closest("tr").remove();
    }

    // Validation (duplicate room check)
    function validateForm() {
        let roomNumbers = [];

        document.querySelectorAll("input[name*='RoomNumber']").forEach(input => {
            if (!input.value) return;

            if (roomNumbers.includes(input.value)) {
                alert("Duplicate Room Number: " + input.value);
                return false;
            }
            roomNumbers.push(input.value);
        });

        return true;
    }

    // Auto add first row
    window.onload = function () {
        addRoom();
    };
</script>