@using ERP_SOLUTIONS.Models.ViewModels
@model HostelWithRoomsVM

@{
    ViewBag.Title = "Edit Hostel";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    .table thead th {
        background: linear-gradient(90deg, #0d9488, #14b8a6) !important;
        color: #fff !important;
        border: none;
    }

    .legend-dot {
        width: 10px;
        height: 10px;
        border-radius: 50%;
        display: inline-block;
    }
</style>

<div class="container mt-5">

    <!-- Header & Add Button -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="text-primary">
                <i class="fas fa-chalkboard"></i> Hostel Management
            </h2>
            <small class="text-muted">Manage Hostels and Rooms provided by school</small>
        </div>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">@TempData["Success"]</div>
    }

    @Html.ValidationSummary(true, "", new { @class = "alert alert-danger" })

    <form method="post">
        @Html.AntiForgeryToken()
        @Html.HiddenFor(m => m.Hostel.HostelId)

        <!-- Hostel Info -->
        <!-- Hostel Info -->
        <div class="card mb-4 shadow-sm">

            <!-- Header -->
            <div class="card-header bg-white d-flex align-items-center">
                <i class="fas fa-hotel text-primary me-2"></i>
                <h6 class="mb-0 fw-bold">Hostel Information</h6>
            </div>

            <!-- Body -->
            <div class="card-body">
                <div class="row g-4">

                    <!-- Hostel Name -->
                    <div class="col-md-6">
                        <label class="form-label fw-semibold">
                            <i class="fas fa-building text-secondary me-1"></i>
                            Hostel Name
                        </label>
                        <div class="input-group">
                            <span class="input-group-text bg-light">
                                <i class="fas fa-signature"></i>
                            </span>
                            @Html.TextBoxFor(m => m.Hostel.HostelName, new {
                            @class = "form-control",
                                                        placeholder = "Enter hostel name"
                                                        })
                        </div>
                    </div>

                    <!-- Location -->
                    <div class="col-md-6">
                        <label class="form-label fw-semibold">
                            <i class="fas fa-map-marker-alt text-danger me-1"></i>
                            Location
                        </label>
                        <div class="input-group">
                            <span class="input-group-text bg-light">
                                <i class="fas fa-location-arrow"></i>
                            </span>
                            @Html.TextBoxFor(m => m.Hostel.Location, new {
                                                        @class = "form-control",
                                                        placeholder = "Enter location"
                                                        })
                        </div>
                    </div>

                </div>
            </div>
        </div>

        <!-- Rooms -->
        <div class="card">
            <div class="card-header bg-white d-flex justify-content-between align-items-center flex-wrap gap-3">
                <!-- Left: Title + Legend -->
                <div>
                    <div class="fw-bold mb-1">
                        <i class="fas fa-door-open text-primary me-2"></i> Rooms
                    </div>

                    <!-- Legend -->
                    <div class="d-flex gap-3 flex-wrap small">

                        <div class="d-flex align-items-center gap-1">
                            <span class="legend-dot bg-success"></span>
                            <span class="text-muted">Empty</span>
                        </div>

                        <div class="d-flex align-items-center gap-1">
                            <span class="legend-dot bg-warning"></span>
                            <span class="text-muted">Available</span>
                        </div>

                        <div class="d-flex align-items-center gap-1">
                            <span class="legend-dot bg-danger"></span>
                            <span class="text-muted">Full</span>
                        </div>

                    </div>
                </div>

                <!-- Right: Button -->
                <button type="button"
                        class="btn btn-primary btn-sm d-flex align-items-center gap-1"
                        onclick="addRoom()">
                    <i class="fas fa-plus"></i> Add Room
                </button>
            </div>

            <div class="card-body">
                <table class="table table-bordered" id="roomTable">
                    <thead>
                        <tr>
                            <th>Room</th>
                            <th>Capacity</th>
                            <th>Status</th>
                            <th>Type</th>
                            <th>Fee</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>

                        @for (int i = 0; i < Model.Rooms.Count; i++)
                        {
                            var r = Model.Rooms[i];
                            string status = "";
                            string cls = "";

                            if (r.OccupiedBeds == 0) 
                            { status = "Empty"; cls = "bg-success"; }
                            else if (r.OccupiedBeds < r.Capacity) { status = "Available"; cls = "bg-warning text-dark"; }
                            else { status = "Full"; cls = "bg-danger"; }

                            <tr>
                                @Html.HiddenFor(m => m.Rooms[i].RoomId)
                                @Html.HiddenFor(m => m.Rooms[i].IsDeleted)

                                <td>@Html.TextBoxFor(m => m.Rooms[i].RoomNumber, new { @class = "form-control" })</td>

                                <td>
                                    @Html.TextBoxFor(m => m.Rooms[i].Capacity, new {
                                    @class = "form-control capacity",
                                                                data_occupied = r.OccupiedBeds
                                                                })
                                </td>

                                <td>
                                    <span class="badge @cls status-badge">
                                        @r.OccupiedBeds / @r.Capacity - @status
                                    </span>
                                </td>

                                <td>@Html.TextBoxFor(m => m.Rooms[i].RoomType, new { @class = "form-control" })</td>
                                <td>@Html.TextBoxFor(m => m.Rooms[i].Fee, new { @class = "form-control" })</td>

                                <td>
                                    @if (r.OccupiedBeds > 0)
                                    {
                                        <!-- Room occupied, show icon instead of button -->
                                        <span class="badge bg-danger-subtle text-danger px-3 py-2" title="Room is occupied">
                                            <i class="fas fa-lock me-1"></i> Occupied
                                        </span>
                                    }
                                    else
                                    {
                                        <!-- Room free, allow deletion -->
                                        <button type="button"
                                                class="btn btn-outline-danger btn-sm d-flex align-items-center gap-1"
                                                onclick="deleteRow(this, @i)"
                                                title="Delete Room">
                                            <i class="fas fa-trash-alt"></i>
                                        </button>
                                    }
                                </td>
                            </tr>
                        }

                    </tbody>
                </table>
            </div>
        </div>

        <br />
        <button class="btn btn-success">Save</button>
    </form>
</div>




<script>
    let roomIndex = @Model.Rooms.Count;

    // Add new room
    function addRoom() {
        let table = document.querySelector("#roomTable tbody");

        let row = `
    <tr>
    <td><input name="Rooms[${roomIndex}].RoomNumber" class="form-control"/></td>
    <td><input name="Rooms[${roomIndex}].Capacity" value="0" class="form-control"/></td>
    <td><span class="badge bg-success status-badge">0 / 0 - Empty</span></td>
    <td><input name="Rooms[${roomIndex}].RoomType" class="form-control"/></td>
    <td><input name="Rooms[${roomIndex}].Fee" class="form-control"/></td>
    <td><button type="button" class="btn btn-danger btn-sm" onclick="removeRow(this)">✖</button></td>
    </tr>`;

        table.insertAdjacentHTML('beforeend', row);
        roomIndex++;
    }

    // Remove new row
    function removeRow(btn) {
        btn.closest("tr").remove();
    }

    // Soft delete existing
    function deleteRow(btn, index) {
        if (!confirm("Delete this room?")) return;

        let row = btn.closest("tr");
        row.style.display = "none";

        document.querySelector(`input[name='Rooms[${index}].IsDeleted']`).value = "true";
    }

    // Live status update
    document.addEventListener("input", function(e) {
        if (e.target.classList.contains("capacity")) {

            let row = e.target.closest("tr");
            let occupied = parseInt(e.target.dataset.occupied || 0);
            let capacity = parseInt(e.target.value || 0);

            if (capacity < occupied) {
                alert("Capacity cannot be less than occupied");
                e.target.value = occupied;
                capacity = occupied;
            }

            let badge = row.querySelector(".status-badge");

            let status = "";
            let cls = "badge ";

            if (occupied === 0) {
                status = "Empty";
                cls += "bg-success";
            } else if (occupied < capacity) {
                status = "Available";
                cls += "bg-warning text-dark";
            } else {
                status = "Full";
                cls += "bg-danger";
            }

            badge.className = cls + " status-badge";
            badge.innerText = `${occupied} / ${capacity} - ${status}`;
        }
    });
</script>