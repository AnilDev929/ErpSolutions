@using ERP_SOLUTIONS.Models.ViewModels
@model IEnumerable<HostelWithRoomsVM>

@{
    ViewBag.Title = "Hostel";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    .table thead {
        background: linear-gradient(90deg, #0d9488, #14b8a6);
        color: white;
        backdrop-filter: blur(6px);
    }

    body.dark .table thead {
        background-color: rgba(255, 255, 255, 0.05);
        color: #f9fafb;
    }

</style>

<div class="container mt-4">

    <div class="d-flex justify-content-between align-items-center mb-4 p-3 bg-white shadow-sm rounded">
        <!-- Left Section -->
        <div class="d-flex align-items-center">
            <div class="me-3 text-primary fs-3">
                <i class="fas fa-hotel"></i>
            </div>
            <div>
                <h5 class="mb-0 fw-bold">Hostel Management</h5>
                <small class="text-muted">Manage hostel provided by school</small>
            </div>
        </div>

        <!-- Right Section -->
        <a href="@Url.Action("Create", "Hostel")" class="btn btn-primary d-flex align-items-center">
            <i class="fas fa-plus me-2"></i> Add Hostel
        </a>
    </div>

    <div class="card shadow-sm">
        <div class="card-body">
            @if (!Model.Any())
            {
                <div class="alert alert-info text-center">
                    No hostels found. Click "Add Hostel" to create one.
                </div>
            }
            else
            {
            <table class="table table-bordered table-hover">
                <thead class="table-dark">
                    <tr>
                        <th>Hostel Name</th>
                        <th>Location</th>
                        <th>Total Rooms</th>
                        <th>Rooms</th>
                        <td>Action</td>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var hostel in Model)
                    {
                            <tr class="align-middle">

                                <!-- Hostel Name -->
                                <td>
                                    <div class="fw-bold">
                                        <i class="fas fa-hotel me-1"></i> @hostel.Hostel.HostelName
                                    </div>
                                </td>

                                <!-- Location -->
                                <td>
                                    <i class="fas fa-map-marker-alt text-danger me-1"></i>
                                    <span class="text-muted">@hostel.Hostel.Location</span>
                                </td>

                                <!-- Total Rooms -->
                                <td>
                                    <span class="badge bg-info text-dark px-3 py-2">
                                        <i class="fas fa-door-open me-1"></i> @hostel.Rooms.Count Rooms
                                    </span>
                                </td>

                                <!-- Rooms List -->
                                <td>
                                    <ul class="mb-0"> 
                                        @foreach (var room in hostel.Rooms) 
                                        {
                                            <li>
                                                <i class="fas fa-bed text-secondary"></i> <strong></strong> Room @room.RoomNumber: @room.Capacity Bed(s)
                                                <span class="badge bg-secondary">@room.RoomType</span> – Fee: <span class="text-success">₹@room.Fee</span>
                                            </li>
                                        }
                                    </ul>


                                    @* <div class="d-flex flex-wrap gap-2">
                                        @foreach (var room in hostel.Rooms)
                                        {
                                            <div class="border rounded px-2 py-1 small bg-light">
                                                <i class="fas fa-bed text-secondary"></i>
                                                <strong>@room.RoomNumber</strong>
                                                <span class="text-muted">
                                                    (@room.Capacity)
                                                </span>
                                                <span class="badge bg-secondary">@room.RoomType</span>
                                                <span class="text-success">₹@room.Fee</span>
                                            </div>
                                        }
                                    </div> *@
                                </td>

                                <!-- Action -->
                                <td>
                                    <a href="@Url.Action("Edit", "Hostel", new { id = hostel.Hostel.HostelId })"
                                       class="btn btn-sm btn-outline-primary">
                                        <i class="fas fa-edit"></i>
                                    </a>
                                </td>

                            </tr>
                    }
                </tbody>
            </table>
            }
        </div>
    </div>

</div>