@using ERP_SOLUTIONS.Models.DTOS
@model TeacherProfileDTO
@{
    ViewData["Title"] = "My Profile";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container mt-4">
    <div class="card shadow-sm">
        <div class="card-header bg-info text-white">
            <h4 class="mb-0"><i class="bi bi-person-circle"></i> @ViewData["Title"]</h4>
        </div>

        <form asp-action="EditMyProfile" method="post">
            <div class="card-body">

                <!-- 🧾 Personal Info -->
                <h5 class="mb-3 text-secondary"><i class="bi bi-person"></i> Personal Info</h5>
                <div class="row mb-3">
                    <div class="col-md-6">
                        <label asp-for="FullName" class="form-label"><i class="bi bi-card-text"></i> Full Name</label>
                        <input asp-for="FullName" class="form-control" />
                    </div>
                    <div class="col-md-3">
                        <label>Gender</label>
                        <input class="form-control" value="@Model.GenderName" disabled />
                    </div>
                    <div class="col-md-3">
                        <label>DOB</label>
                        <input class="form-control" value="@Model.DateOfBirth?.ToString("yyyy-MM-dd")" disabled />
                    </div>
                </div>

                <!-- 👨‍👩‍👧 Family Info -->
                <h5 class="mb-3 text-secondary"><i class="bi bi-people"></i> Family Info</h5>
                <div class="row mb-3">
                    <div class="col-md-6">
                        <label>Father Name</label>
                        <input class="form-control" value="@Model.FatherName" disabled />
                    </div>
                    <div class="col-md-6">
                        <label>Mother Name</label>
                        <input class="form-control" value="@Model.MotherName" disabled />
                    </div>
                </div>

                @if (Model.IsMarried)
                {
                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label>Spouse Name</label>
                            <input class="form-control" value="@Model.SpouseName" disabled />
                        </div>
                        <div class="col-md-6">
                            <label>Spouse Contact</label>
                            <input class="form-control" value="@Model.SpouseContact" disabled />
                        </div>
                    </div>
                }

                <!-- 📞 Contact Info -->
                <h5 class="mb-3 text-secondary"><i class="bi bi-telephone-fill"></i> Contact Info</h5>
                <div class="row mb-3">
                    <div class="col-md-4">
                        <label asp-for="Phone" class="form-label"><i class="bi bi-telephone"></i> Phone</label>
                        <input asp-for="Phone" class="form-control" />
                    </div>
                    <div class="col-md-4">
                        <label asp-for="EmailID" class="form-label"><i class="bi bi-envelope"></i> Email</label>
                        <input asp-for="EmailID" class="form-control" />
                    </div>
                    <div class="col-md-4">
                        <label asp-for="EmergencyContact" class="form-label"><i class="bi bi-exclamation-triangle"></i> Emergency Contact</label>
                        <input asp-for="EmergencyContact" class="form-control" />
                    </div>
                </div>
                <div class="row mb-3">
                    <div class="col-md-6">
                        <label asp-for="PresentAddress" class="form-label"><i class="bi bi-house"></i> Present Address</label>
                        <textarea asp-for="PresentAddress" class="form-control"></textarea>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="PermanentAddress" class="form-label"><i class="bi bi-house-door"></i> Permanent Address</label>
                        <textarea asp-for="PermanentAddress" class="form-control"></textarea>
                    </div>
                </div>

                <!-- 🎓 Professional Info -->
                <h5 class="mb-3 text-secondary"><i class="bi bi-mortarboard"></i> Professional Info</h5>
                <div class="row mb-3">
                    <div class="col-md-6">
                        <label asp-for="Qualification" class="form-label"><i class="bi bi-journal-text"></i> Qualification</label>
                        <input asp-for="Qualification" class="form-control" />
                    </div>
                    <div class="col-md-6">
                        <label asp-for="Specialization" class="form-label"><i class="bi bi-book"></i> Specialization</label>
                        <input asp-for="Specialization" class="form-control" />
                    </div>
                </div>
                <div class="row mb-3">
                    <div class="col-md-2">
                        <label asp-for="Experience" class="form-label"><i class="bi bi-hourglass-split"></i> Experience (yrs)</label>
                        <input asp-for="Experience" type="number" step="0.1" class="form-control" />
                    </div>
                </div>

            </div>

            <!-- Footer Save/Update -->
            <div class="card-footer text-end">
                <button type="submit" class="btn btn-primary"><i class="bi bi-save"></i> Update</button>
            </div>
        </form>
    </div>
</div>