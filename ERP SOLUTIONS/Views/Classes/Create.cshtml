@using ERP_SOLUTIONS.Models.Entities
@model SchoolClass

@{
    ViewData["Title"] = "Create Class";
    Layout = "~/Views/Shared/_Layout.cshtml";
}


<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-lg-7 col-md-9">
            <div class="card border shadow-sm rounded-4">

                <!-- Header -->
                <div class="card-header bg-white border-bottom py-3 px-4">
                    <h4 class="fw-bold text-dark mb-1">
                        <i class="fas fa-chalkboard text-primary me-2"></i>
                        Create New Class
                    </h4>
                    <p class="text-muted mb-0 small">
                        Add class details for your college system
                    </p>
                </div>

                <!-- Body -->
                <div class="card-body p-4">

                    <form asp-action="Create">

                        <!-- Class Name -->
                        <div class="mb-4">
                            <label class="form-label fw-semibold text-muted">Class Name</label>
                            <div class="input-group">
                                <span class="input-group-text bg-light border-0">
                                    <i class="fas fa-chalkboard text-primary"></i>
                                </span>
                                <input asp-for="ClassName" class="form-control border-start-0"
                                       placeholder="e.g. BSc Computer Science" />
                            </div>
                            <span asp-validation-for="ClassName" class="text-danger small"></span>
                        </div>

                        <!-- Stream -->
                        <div class="mb-4">
                            <label class="form-label fw-semibold text-muted">Stream</label>
                            <div class="input-group">
                                <span class="input-group-text bg-light border-0">
                                    <i class="fas fa-book-open text-primary"></i>
                                </span>
                                <input asp-for="Stream" class="form-control border-start-0"
                                       placeholder="Science / Commerce / Arts" />
                            </div>
                        </div>

                        <!-- Department Code -->
                        <div class="mb-4">
                            <label class="form-label fw-semibold text-muted">Department Code</label>
                            <div class="input-group">
                                <span class="input-group-text bg-light border-0">
                                    <i class="fas fa-hashtag text-primary"></i>
                                </span>
                                <input asp-for="DeptCode" class="form-control border-start-0"
                                       placeholder="Optional (e.g. CS101)" />
                            </div>
                        </div>

                        <!-- Duration + Status -->
                        <div class="row mb-2">

                            <!-- Duration -->
                            <div class="col-md-7 mb-3">
                                <label class="form-label fw-semibold text-muted">Course Duration</label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light border-0">
                                        <i class="fas fa-clock text-primary"></i>
                                    </span>
                                    <input asp-for="Duration" class="form-control border-start-0"
                                           placeholder="Duration in years" />
                                </div>
                            </div>

                            <!-- Status -->
                            <div class="col-md-5 d-flex align-items-end mb-3">
                                <div class="form-check form-switch mt-2">
                                    <input asp-for="IsActive" class="form-check-input" />
                                    <label class="form-check-label ms-2 text-muted fw-semibold">
                                        Active Status
                                    </label>
                                </div>
                            </div>

                        </div>

                        <!-- Buttons -->
                        <div class="d-flex justify-content-between mt-4 pt-2 border-top">
                            <a asp-action="Index" class="btn btn-light border rounded-pill px-4">
                                Cancel
                            </a>

                            <button type="submit" class="btn btn-primary rounded-pill px-4 shadow-sm">
                                <i class="fas fa-check me-2"></i> Save Class
                            </button>
                        </div>

                    </form>

                </div>
            </div>

        </div>
    </div>
</div>

