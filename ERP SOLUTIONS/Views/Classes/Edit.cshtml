@using ERP_SOLUTIONS.Models.Entities
@model SchoolClass

@{
    ViewData["Title"] = "Edit Class";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    
    /* Card */
    .form-card {
        width: 100%;
        max-width: 520px;
        border-radius: 16px;
        border: 1px solid #e3e6f0;
        overflow: hidden;
    }

    /* Header */
    .form-card .card-header {
        border-bottom: 2px solid #e8edff;
    }

    .custom-input .form-control {
        border-left: 0;
        border-radius: 0 8px 8px 0;
        transition: all 0.3s ease;
    }

    .custom-input .input-group-text {
        background: #f8f9fa;
        border-radius: 8px 0 0 8px;
        color: #0d6efd;
    }

    .custom-input .form-control:focus {
        box-shadow: 0 0 8px rgba(13, 110, 253, 0.25);
        border-color: #0d6efd;
    }

    .form-label {
        font-weight: 500;
    }

    .btn-primary {
        border-radius: 8px;
    }

    .btn-outline-secondary {
        border-radius: 8px;
    }
</style>


<div class="container-fluid mt-4">
    <!-- Centered Card -->
    <div class="d-flex justify-content-center">

        <div class="card form-card shadow-lg border-0 rounded-4">

            <!-- Card Header -->
            <div class="card-header bg-white border-0 py-3 px-4">
                <h5 class="mb-0 fw-semibold text-primary">
                    <i class="fas fa-user-edit text-primary me-2"></i> Edit Class Information
                </h5>
                <small class="text-muted">Update class details</small>
            </div>

            <div class="card-body p-4">

                <form asp-action="Edit">
                    <input type="hidden" asp-for="ClassID" />

                    <!-- Class Name -->
                    <div class="mb-3">
                        <label asp-for="ClassName" class="form-label"></label>
                        <div class="input-group custom-input">
                            <span class="input-group-text"><i class="fa fa-chalkboard"></i></span>
                            <input asp-for="ClassName" class="form-control" placeholder="Enter class name" />
                        </div>
                        <span asp-validation-for="ClassName" class="text-danger small"></span>
                    </div>

                    <!-- Stream -->
                    <div class="mb-3">
                        <label asp-for="Stream" class="form-label"></label>
                        <div class="input-group custom-input">
                            <span class="input-group-text"><i class="fa fa-layer-group"></i></span>
                            <input asp-for="Stream" class="form-control" placeholder="Science / Commerce / Arts" />
                        </div>
                        <span asp-validation-for="Stream" class="text-danger small"></span>
                    </div>

                    <!-- Dept Code -->
                    <div class="mb-3">
                        <label asp-for="DeptCode" class="form-label"></label>
                        <div class="input-group custom-input">
                            <span class="input-group-text"><i class="fa fa-code"></i></span>
                            <input asp-for="DeptCode" class="form-control" placeholder="Optional department code" />
                        </div>
                        <span asp-validation-for="DeptCode" class="text-danger small"></span>
                    </div>

                    <!-- Duration -->
                    <div class="mb-3">
                        <label asp-for="Duration" class="form-label"></label>
                        <div class="input-group custom-input">
                            <span class="input-group-text"><i class="fa fa-clock"></i></span>
                            <input asp-for="Duration" class="form-control" placeholder="Duration (months)" />
                        </div>
                    </div>

                    <!-- Active Toggle -->
                    <div class="form-check form-switch mb-4">
                        <input asp-for="IsActive" class="form-check-input" type="checkbox" />
                        <label asp-for="IsActive" class="form-check-label">Active Class</label>
                    </div>

                    <!-- Buttons -->
                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary px-4">
                            <i class="fa fa-save"></i> Update
                        </button>
                        <a asp-action="Index" class="btn btn-outline-secondary px-4">
                            Back
                        </a>
                    </div>
                </form>
            </div>

        </div>

    </div>
</div>



@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}