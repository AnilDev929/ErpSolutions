@using ERP_SOLUTIONS.Models.Entities
@model IEnumerable<SchoolClass>


@{
    ViewData["Title"] = "School Class";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    /* Badge subtle colors (Bootstrap 5.3+) fallback */
    .bg-success-subtle {
        background-color: #d1e7dd;
    }

    .bg-danger-subtle {
        background-color: #f8d7da;
    }
</style>

<div class="container mt-4">

    <!-- Page Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <!-- Left Side -->
        <div>
            <h3 class="fw-bold mb-1 d-flex align-items-center">
                <i class="fas fa-chalkboard text-primary me-2"></i>
                Class Management
                <span class="badge bg-primary ms-2">@Model.Count()</span>
            </h3>
            <p class="text-muted mb-0 small">
                Manage classes provided by college
            </p>
        </div>

        <!-- Right Side -->
        <a asp-action="Create" class="btn btn-primary rounded-pill px-4 shadow-sm">
            <i class="fas fa-plus me-2"></i> Add Class
        </a>
    </div>

    <!-- Success Message -->
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show">
            @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <!-- Card -->
    <div class="card shadow-sm border-0">
        <div class="card-body p-0">

            <div class="table-responsive">
                <table class="table table-hover table-striped mb-0 align-middle">

                    <thead class="table-light">
                        <tr>
                            <th class="ps-4">#</th>
                            <th>Class Name</th>
                            <th>Stream</th>
                            <th>Dept Code</th>
                            <th>Duration</th>
                            <th>Status</th>
                            <th class="text-center" style="width:150px;">Actions</th>
                        </tr>
                    </thead>

                    <tbody id="classTableBody">

                        @if (!Model.Any())
                        {
                            <tr>
                                <td colspan="6" class="text-center text-muted py-4">
                                    <i class="bi bi-inbox fs-4"></i>
                                    <div>No classes found</div>
                                </td>
                            </tr>
                        }
                        else
                        {
                            int count = 1;
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td class="ps-4 text-muted">@count</td>
                                    <td class="fw-semibold">@item.ClassName</td>

                                    <td>@item.Stream</td>

                                    <td>
                                        @(string.IsNullOrEmpty(item.DeptCode)
                                                                        ? "-"
                                                                        : item.DeptCode)
                                                                                    </td>

                                    <td>
                                        @(item.Duration.HasValue
                                                                        ? item.Duration + " Yrs"
                                                                        : "-")
                                    </td>

                                    <!-- Status -->
                                    <td>
                                    @if (item.IsActive)
                                        {
                                            <span class="badge bg-success-subtle text-success px-3 py-2">
                                                <i class="bi bi-check-circle"></i> Active
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-danger-subtle text-danger px-3 py-2">
                                                <i class="bi bi-x-circle"></i> Inactive
                                            </span>
                                        }
                                    </td>

                                    <!-- Actions -->
                                    <td class="text-center">
                                        <a asp-action="Edit" asp-route-id="@item.ClassID"
                                           class="btn btn-sm btn-warning rounded-circle me-1"
                                           data-bs-toggle="tooltip" title="Edit">
                                            <i class="fas fa-pen-to-square"></i>
                                        </a>

                                        <a asp-action="Details" asp-route-id="@item.ClassID"
                                           class="btn btn-sm btn-info text-white rounded-circle me-1"
                                           data-bs-toggle="tooltip" title="View">
                                            <i class="fas fa-eye"></i>
                                        </a>

                                        <a asp-action="Delete" asp-route-id="@item.ClassID"
                                           class="btn btn-sm btn-danger rounded-circle"
                                           data-bs-toggle="tooltip"
                                           title="Delete"
                                           onclick="return confirm('Are you sure you want to delete this class?');">
                                            <i class="fas fa-trash"></i>
                                        </a>
                                    </td>

                                </tr>
                                count++;
                            }
                        }

                    </tbody>

                </table>
            </div>

        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Live search/filter
        document.getElementById('searchInput').addEventListener('keyup', function () {
            var filter = this.value.toLowerCase();
            var rows = document.querySelectorAll('#classTableBody tr');

            rows.forEach(row => {
                var text = row.innerText.toLowerCase();
                row.style.display = text.includes(filter) ? '' : 'none';
            });
        });
    </script>
}