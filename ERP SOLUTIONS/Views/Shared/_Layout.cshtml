@{
    // Get current controller and action to highlight active menu
    string currentController = ViewContext.RouteData.Values["controller"]?.ToString();
    string currentAction = ViewContext.RouteData.Values["action"]?.ToString();
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewBag.Title - School ERP</title>

    <link href="~/css/site.css" rel="stylesheet" />
    <!-- Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.1/dist/css/bootstrap.min.css" rel="stylesheet" />
    <!-- FontAwesome -->
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet" />
    
    <style>
        body {
             height: 100vh;       /* fix height */
            overflow: hidden;    /* prevent full page scroll */
            display: flex;
            flex-direction: column; /* ADD THIS */
        }

        .main-wrapper {
            flex: 1; /* pushes footer down */
            display: flex;
            overflow: hidden; /* important */
        }

        #content {
            flex: 1;
            padding: 20px;
            overflow-y: auto; /* scroll only here */
        }

        /* Sidebar */
        #sidebar {
            min-width: 220px;
            max-width: 220px;
            background-color: #343a40;
            color: #fff;
            /* min-height: 100vh; */
            transition: all 0.3s;
            height: 100%; /* instead of min-height */
        }

        #sidebar.collapsed {
            margin-left: -220px;
        }

        #sidebar .nav-link {
            color: #fff;
            font-size: 16px;
        }

        #sidebar .nav-link:hover {
            background-color: #495057;
            color: #fff;
        }

        #sidebar .nav-link i {
            margin-right: 10px;
        }

        #sidebar .dropdown-menu {
            background-color: #343a40; /* match sidebar bg */
        }

        #sidebar .dropdown-item {
            color: #fff;
        }

        #sidebar .dropdown-item:hover,
        #sidebar .dropdown-item:focus {
            background-color: #495057; /* hover background like nav-links */
            color: #fff;
        }

        /* Main content */
        #content {
            flex: 1;
            padding: 20px;
            transition: all 0.3s;
        }

        /* Card hover effect */
        .dashboard-card {
            transition: transform 0.2s, box-shadow 0.2s;
            cursor: pointer;
        }

        .dashboard-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 8px 20px rgba(0,0,0,0.2);
        }

        /* Master Data submenu hover */
        #adminMasterData .nav-link:hover {
            background-color: #495057;
            color: #fff;
        }

        /* Chevron rotates when expanded */
        .nav-link.collapsed i.fas.fa-chevron-down {
            transition: transform 0.3s;
        }

        .nav-link[aria-expanded="true"] i.fas.fa-chevron-down {
            transform: rotate(180deg);
        }

        .footer {
            background: #343a40;
        }

        .custom-navbar {
            padding: 12px 20px; /* increase height */
            background: linear-gradient(to right, #ffffff, #f8f9fc);
            border-bottom: 2px solid #4e73df;
        }

        .custom-navbar .navbar-brand {
            font-size: 22px;
            letter-spacing: 0.5px;
        }

        .dropdown-menu {
            min-width: 220px;
            max-height: 300px;
            overflow-y: auto;
        }
        .user-info span {
            font-size: 16px;
        }

        .profile-dropdown {
            min-width: 260px;
            border-radius: 10px;
            overflow: hidden;
        }

        .profile-dropdown .dropdown-item {
            padding: 10px 16px;
            transition: background 0.2s;
        }

        .profile-dropdown .dropdown-item:hover {
            background-color: #f1f5ff;
        }

        .profile-btn {
            display: flex;
            align-items: center;
            gap: 10px;
            background: #f8f9fc;
            border: none;
            border-radius: 30px;
            padding: 6px 14px;
            transition: all 0.2s ease;
        }

        .profile-btn:hover {
            background: #e9f0ff;
        }

        .profile-avatar {
            width: 36px;
            height: 36px;
            border-radius: 50%;
            background: #4e73df;
            color: #fff;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 16px;
        }

        .profile-text {
            display: flex;
            flex-direction: column;
            line-height: 1.1;
        }

        .profile-name {
            font-weight: 600;
            font-size: 14px;
        }

        .profile-role {
            font-size: 12px;
            color: #6c757d;
        }
    </style>
</head>

<body>

    <div class="main-wrapper d-flex flex-grow-1">

        <!-- Sidebar -->
        <div id="sidebar" class="d-flex flex-column p-3">
            <a href="@Url.Action("Dashboard", "Home")" class="navbar-brand mb-4 text-white fs-4">
                <i class="fas fa-school me-2"></i> School ERP
            </a>
            <ul class="nav nav-pills flex-column">
                <li class="nav-item">
                    <a class="nav-link" href="@Url.Action("Index", "Dashboard")">
                        <i class="fas fa-tachometer-alt"></i> Dashboard
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link collapsed" data-bs-toggle="collapse" href="#adminMasterData" role="button" aria-expanded="false" aria-controls="adminMasterData">
                        <i class="fas fa-cogs me-2"></i> Master Data
                        <i class="fas fa-chevron-down ms-auto"></i>
                    </a>
                    <div class="collapse" id="adminMasterData">
                        <ul class="btn-toggle-nav list-unstyled fw-normal pb-1 small">
                            <li>
                                <a href="@Url.Action("Index", "Roles")" class="nav-link">
                                    <i class="fas fa-user-shield me-2"></i> Roles
                                </a>
                            </li>
                            <li>
                                <a href="@Url.Action("Index", "AcademicYears")" class="nav-link">
                                    <i class="fas fa-user-shield me-2"></i> Academic Year
                                </a>
                            </li>
                            <li>
                                <a href="@Url.Action("Index", "Holidays")" class="nav-link">
                                    <i class="fas fa-calendar-alt me-2"></i> Holidays
                                </a>
                            </li>
                            <li>
                                <a href="@Url.Action("Index", "Subjects")" class="nav-link">
                                    <i class="fas fa-school me-2"></i> Subjects
                                </a>
                            </li>
                            <li>
                                <a href="@Url.Action("Index", "Classes")" class="nav-link">
                                    <i class="fas fa-school me-2"></i> Classes
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" href="@Url.Action("Index", "Fees")">
                                    <i class="fas fa-wallet"></i> Course Fees
                                </a>
                            </li>
                            <li>
                                <a class="nav-link" href="@Url.Action("Create", "Hostel")">
                                    <i class="fas fa-wallet"></i> Hostel Management
                                </a>
                            </li>
                        </ul>
                    </div>
                </li>

                <li class="nav-item dropdown">
                    <a class="nav-link" href="@Url.Action("Index", "Teachers")" id="teacherssDropdown" 
                    role="button" data-bs-toggle="dropdown" aria-expanded="false">
                        <i class="fas fa-chalkboard-teacher"></i> Teachers
                    </a>
                    <ul class="dropdown-menu bg-dark border-0" aria-labelledby="teacherssDropdown">
                        <li><a class="dropdown-item text-white @(currentAction == "Entry" ? "active" : "")" href="@Url.Action("Entry", "Teachers")">New Techer</a></li>
                        <li><a class="dropdown-item text-white @(currentAction == "Entry" ? "active" : "")" href="@Url.Action("Salary", "Teachers")">Techer Salary</a></li>
                        <li><a class="dropdown-item text-white @(currentAction == "Entry" ? "active" : "")" href="@Url.Action("Attandance", "Teachers")">Attandance</a></li>
                    </ul>
                </li>

                <!-- Students dropdown example -->
                @* <li class="nav-item dropdown @(currentController == "Students" ? "active" : "")">
                    <a class="nav-link dropdown-toggle" href="#" id="studentsDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                        <i class="fas fa-user-graduate"></i> <span>Students</span>
                    </a>
                    <ul class="dropdown-menu bg-dark border-0" aria-labelledby="studentsDropdown">
                        <li><a class="dropdown-item text-white @(currentAction == "Entry" ? "active" : "")" href="@Url.Action("Entry", "Students")">Student Entry</a></li>
                        <li><a class="dropdown-item text-white @(currentAction == "Fees" ? "active" : "")" href="@Url.Action("Fees", "Students")">Fees</a></li>
                        <li><a class="dropdown-item text-white @(currentAction == "Marks" ? "active" : "")" href="@Url.Action("Marks", "Students")">Marks</a></li>
                        <li><a class="dropdown-item text-white @(currentAction == "Exam" ? "active" : "")" href="@Url.Action("Exam", "Students")">Exam</a></li>
                    </ul>
                </li> *@

                <li class="nav-item">
                    <a class="nav-link collapsed @(currentController == "Students" ? "active" : "")" 
                    data-bs-toggle="collapse" href="#studentsDropdown" role="button" 
                    aria-expanded="false" aria-controls="studentsDropdown">
                        <i class="fas fa-user-graduate me-2"></i> <span>Students</span>
                        <i class="fas fa-chevron-down ms-auto"></i>
                    </a>
                    <div class="collapse" id="studentsDropdown">
                        <ul class="btn-toggle-nav list-unstyled fw-normal pb-1 small">

                            <!-- Student Entry -->
                            <li>
                                <a href="@Url.Action("Entry", "Students")"
                                   class="nav-link text-white @(currentAction == "Entry" ? "active" : "")">
                                    <i class="fas fa-user-graduate me-2"></i> Student Entry
                                </a>
                            </li>

                            <!-- Fees -->
                            <li>
                                <a href="@Url.Action("Fees", "Students")"
                                   class="nav-link text-white @(currentAction == "Fees" ? "active" : "")">
                                    <i class="fas fa-wallet me-2"></i> Fees
                                </a>
                            </li>

                            <!-- Attendance -->
                            <li>
                                <a href="@Url.Action("Attendance", "Students")"
                                   class="nav-link text-white @(currentAction == "Attendance" ? "active" : "")">
                                    <i class="fas fa-calendar-check me-2"></i> Attendance
                                </a>
                            </li>

                            <!-- Exam -->
                            <li>
                                <a href="@Url.Action("Exam", "Students")"
                                   class="nav-link text-white @(currentAction == "Exam" ? "active" : "")">
                                    <i class="fas fa-file-alt me-2"></i> Exam
                                </a>
                            </li>

                            <!-- Marks -->
                            <li>
                                <a href="@Url.Action("Marks", "Students")"
                                   class="nav-link text-white @(currentAction == "Marks" ? "active" : "")">
                                    <i class="fas fa-chart-line me-2"></i> Marks
                                </a>
                            </li>

                        </ul>
                    </div>
                </li>

                <li class="nav-item mt-auto">
                    <a class="nav-link" href="@Url.Action("Logout", "Account")">
                        <i class="fas fa-sign-out-alt"></i> Logout
                    </a>
                </li>
            </ul>
        </div>

        <!-- Main Content -->
        <div id="content">

            <!-- Top Navbar (Improved Header) -->
            <nav class="navbar navbar-expand-lg navbar-light bg-light mb-3 shadow-sm custom-navbar">
                <div class="container-fluid">

                    <!-- Sidebar toggle -->
                    <button class="btn btn-outline-secondary d-lg-none me-2" id="toggleSidebar">
                        <i class="fas fa-bars"></i>
                    </button>

                    <!-- Right side -->
                    <div class="ms-auto d-flex align-items-center">

                        <!-- 🌙 Dark Mode Toggle -->
                        <button id="darkModeToggle" class="btn btn-light btn-sm shadow-sm"
                                title="Toggle Dark Mode">
                            <i class="fas fa-moon"></i> Dark Mode
                        </button>

                        <!-- 🔔 Notifications -->
                        <div class="dropdown me-3">
                            <button class="btn btn-light position-relative" data-bs-toggle="dropdown">
                                <i class="fas fa-bell fa-lg"></i>
                                <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger">
                                    3
                                </span>
                            </button>

                            <ul class="dropdown-menu dropdown-menu-end shadow">
                                <li class="dropdown-header fw-bold">Notifications</li>
                                <li><a class="dropdown-item" href="#">New student registered</a></li>
                                <li><a class="dropdown-item" href="#">Fee payment received</a></li>
                                <li><a class="dropdown-item" href="#">Exam schedule updated</a></li>
                                <li><hr class="dropdown-divider"></li>
                                <li><a class="dropdown-item text-center" href="#">View all</a></li>
                            </ul>
                        </div>

                        <!-- 👤 Profile Dropdown -->
                        <div class="dropdown">
                            <button class="profile-btn dropdown-toggle d-flex align-items-center" data-bs-toggle="dropdown">
                                <div class="profile-avatar">
                                    <i class="fas fa-user"></i>
                                </div>
                                <div class="profile-text">
                                    <span class="profile-name">@User.Identity.Name</span>
                                </div>
                            </button>

                            <ul class="dropdown-menu dropdown-menu-end shadow profile-dropdown">

                                <!-- User Info Header -->
                                <li class="px-3 py-2 border-bottom d-flex align-items-center">
                                    <div>
                                        <div class="fw-semibold">@User.Identity.Name
                                        <small class="text-muted">(@User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value)</small>
                                        </div>
                                    </div>
                                </li>

                                <!-- Menu Items -->
                                <li>
                                    <a class="dropdown-item d-flex align-items-center" href="@Url.Action("MyProfile", "Students")">
                                        <i class="fas fa-user me-2 text-secondary"></i> My Profile
                                    </a>
                                </li>

                                <li>
                                    <a class="dropdown-item d-flex align-items-center" href="#">
                                        <i class="fas fa-cog me-2 text-secondary"></i> Settings
                                    </a>
                                </li>

                                <li><hr class="dropdown-divider"></li>

                                <!-- Logout -->
                                <li>
                                    <a class="dropdown-item d-flex align-items-center text-danger" href="@Url.Action("Logout", "Account")">
                                        <i class="fas fa-sign-out-alt me-2"></i> Logout
                                    </a>
                                </li>

                            </ul>
                        </div>

                    </div>

                </div>
            </nav>


            <!-- Page Content -->
            @RenderBody()
        </div>
    </div>

    <footer class="footer text-center text-white py-2">
    <small>&copy; @DateTime.Now.Year School ERP</small>
</footer>

    <!-- Scripts -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.1/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        // Toggle sidebar on mobile
        const toggleBtn = document.getElementById('toggleSidebar');
        const sidebar = document.getElementById('sidebar');
        toggleBtn.addEventListener('click', () => {
            sidebar.classList.toggle('collapsed');
        });

            const toggle = document.getElementById("darkModeToggle");
        toggle.addEventListener("click", () => {
            document.body.classList.toggle("dark-mode");

            // Save preference
            if (document.body.classList.contains("dark-mode")) {
                localStorage.setItem("theme", "dark");
                toggle.innerHTML = '<i class="fas fa-sun"></i> Light Mode';
            } else {
                localStorage.setItem("theme", "light");
                toggle.innerHTML = '<i class="fas fa-moon"></i> Dark Mode';
            }
        });

        // Apply saved preference on page load
        if (localStorage.getItem("theme") === "dark") {
            document.body.classList.add("dark-mode");
            toggle.innerHTML = '<i class="fas fa-sun"></i> Light Mode';
        }
    </script>

    @RenderSection("Scripts", required: false)

</body>

</html>