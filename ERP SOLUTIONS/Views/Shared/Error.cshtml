@{
    ViewData["Title"] = "Error";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    .error-card {
        max-width: 500px;
        margin: auto;
    }
</style>

<div class="container-fluid d-flex align-items-center justify-content-center" style="min-height:70vh;">

    <div class="text-center">

        <div class="mb-4">
            <i class="fas fa-exclamation-triangle text-danger" style="font-size:60px;"></i>
        </div>

        <h2 class="fw-bold text-dark">Oops! Something went wrong</h2>

        <p class="text-muted mt-2">
            We couldn't process your request. Please try again or contact support.
        </p>

        <div class="mt-4">
            <a href="@Url.Action("Index", "Dashboard")" class="btn btn-primary rounded-pill px-4 me-2">
                <i class="fas fa-home me-2"></i> Go to Dashboard
            </a>

            <a href="javascript:history.back()" class="btn btn-outline-secondary rounded-pill px-4">
                <i class="fas fa-arrow-left me-2"></i> Go Back
            </a>
        </div>

    </div>

</div>